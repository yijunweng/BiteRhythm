/** miniprogram/app.wxss **/
@import "iconfont.wxss";

::-webkit-scrollbar,
page::-webkit-scrollbar,
scroll-view::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  color: transparent !important;
}

/* 全局设计变量 - 极简乳白/香槟金风格 */
page {
  min-height: 100%;
  --primary: #2A2A2A;           /* 曜石墨黑 */
  --primary-hover: #151515;
  --gold: #D4B28C;              /* 柔和香槟金 */
  --gold-light: #F7F3EA;        /* 淡金底色 */
  --bg: #FDFDFB;                /* 极轻柔乳白 */
  --card-bg: #FFFFFF;           /* 纯白卡片 */
  --border: #F3EFE9;            /* 奶油灰边框 */
  --text-main: #222222;         /* 炭黑主文字 */
  --text-muted: #9E9E9E;        /* 柔灰辅助 */
  --text-light: #C5C5C5;        /* 极浅灰 */
  --shadow: 0 8rpx 48rpx rgba(188, 179, 166, 0.08);
  --shadow-md: 0 16rpx 64rpx rgba(188, 179, 166, 0.12);
  --radius-sm: 12rpx;
  --radius: 24rpx;
  --radius-lg: 32rpx;
  --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);

  /* 统一主题色定义（可指向 var(--gold) 或 var(--primary)） */
  --theme-color: var(--gold);

  background-color: var(--bg);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

view, text, scroll-view, input, button, textarea, label {
  box-sizing: border-box;
}

/* 页面容器 */
.page-container {
  min-height: 100%;
  background: var(--bg);
  padding: 0 32rpx;
  padding-bottom: 32rpx;
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
  border: 1rpx solid var(--border);
}

/* 主要按钮：背景色为主题色，字色为白色 */
.btn-primary {
  width: 100%;
  background: var(--theme-color);
  color: #FFFFFF;
  border: none;
  padding: 28rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 178, 140, 0.12);
  transition: var(--transition);
  line-height: 1;
}

.btn-primary[disabled] {
  background: var(--border) !important;
  color: var(--text-muted) !important;
  box-shadow: none !important;
  opacity: 0.6;
}

.btn-primary-hover {
  opacity: 0.9;
  filter: brightness(0.95);
}

/* 次要按钮：背景色为白色，字色为主题色，边框为主题色 */
.btn-secondary {
  width: 100%;
  background: #FFFFFF;
  color: var(--theme-color);
  border: 2rpx solid var(--theme-color);
  padding: 28rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: var(--transition);
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.btn-secondary-hover {
  background: #FAF7F2;
  opacity: 0.9;
}

/* 其他按钮 (深底)：text类型，字色为白色 */
.btn-text-white {
  background: transparent;
  color: #FFFFFF;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 26rpx;
  line-height: normal;
  display: inline-block;
}

/* 其他按钮 (浅底)：text类型，字色为主题色 */
.btn-text-theme {
  background: transparent;
  color: var(--theme-color);
  border: none;
  padding: 0;
  margin: 0;
  font-size: 26rpx;
  font-weight: 600;
  line-height: normal;
  display: inline-block;
}

/* 其他按钮 (浅底辅助)：text类型，字色为柔灰 */
.btn-text-muted {
  background: transparent;
  color: var(--text-muted);
  border: none;
  padding: 0;
  margin: 0;
  font-size: 26rpx;
  line-height: normal;
  display: inline-block;
}

/* 重要操作按钮（删除等）：text 红色 */
.btn-danger-text {
  background: transparent;
  color: #E53935;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 26rpx;
  font-weight: 600;
  line-height: normal;
  display: inline-block;
}

/* 通用输入框 */
.input-field {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  background: #FDFDFB;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-main);
  transition: var(--transition);
}

/* 标签/角色胶囊 */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.badge-gold {
  background: var(--gold-light);
  color: var(--gold);
}

.badge-blue {
  background: #E3F2FD;
  color: #1E88E5;
}

.badge-red {
  background: #FFEBEE;
  color: #E53935;
}

/* 空状态占位 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.8;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 列表淡入动画 */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-in {
  animation: fadeUp 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(47, 62, 70, 0.4);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: maskFadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes maskFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-sheet {
  background: #FFFFFF;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 48rpx 32rpx;
  padding-bottom: 64rpx;
  width: 100%;
  animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.form-picker {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  background: #FDFDFB;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-main);
  justify-content: space-between;
}

/* Shimmer 加载骨架屏 */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.shimmer-line {
  height: 32rpx;
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 50%, #F0F0F0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

/* 只读提示横幅 */
.read-only-banner {
  background: #FFF9C4;
  color: #F57F17;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 节标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 24rpx;
}

/* 自定义 Select/Picker 组件 */
.custom-select-container {
  position: relative;
  width: 100%;
}

.custom-select-container.cat-select {
  width: auto;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card-bg);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-main);
  transition: var(--transition);
}

.form-picker.active {
  border-color: var(--theme-color);
  box-shadow: 0 0 0 3rpx rgba(212, 178, 140, 0.15);
}

.select-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  transition: transform 0.2s ease;
}

.select-arrow.open {
  transform: rotate(180deg);
}

.custom-select-options {
  position: absolute;
  top: calc(100% + 8rpx);
  left: 0;
  width: 100%;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-lg);
  z-index: 1000;
  display: none;
  max-height: 400rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.custom-select-options.cat-options {
  width: 160rpx;
}

.custom-select-container.open-up .custom-select-options {
  top: auto;
  bottom: calc(100% + 8rpx);
}

.custom-select-options.show {
  display: block;
  animation: fadeInDown 0.15s ease-out;
}

.custom-select-container.open-up .custom-select-options.show {
  animation: fadeInUp 0.15s ease-out;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.custom-select-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-main);
  transition: var(--transition);
}

.custom-select-option:hover,
.custom-select-option:active {
  background: var(--bg-main);
}

.custom-select-option.selected {
  color: var(--theme-color);
  font-weight: 600;
  background: #FCFAF2;
}

.custom-select-option .iconfont-right {
  font-size: 24rpx;
  color: var(--theme-color);
}

/* 遮罩层，用于点击空白关闭 */
.custom-select-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: transparent;
}

/* ============================================================
   自定义 Toast & Loading 全局样式
   ============================================================ */
.custom-toast-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99998;
  background: rgba(0, 0, 0, 0.06);
}

.custom-toast {
  position: fixed;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  z-index: 99999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  pointer-events: none;
}

.custom-toast.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.custom-toast-content {
  background: rgba(33, 33, 33, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 36rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 240rpx;
  max-width: 420rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.24);
}

.custom-toast-title {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
  white-space: pre-line;
}

/* 当有图标或加载圈时，添加 margin-top */
.custom-toast-loading-spinner ~ .custom-toast-title,
.custom-toast-icon ~ .custom-toast-title {
  margin-top: 16rpx;
}

/* 成功/信息图标 */
.custom-toast-icon {
  font-size: 64rpx;
  line-height: 1;
  display: block;
}

.custom-toast-icon.success {
  color: var(--theme-color);
}

.custom-toast-icon.info {
  color: #FFB74D;
}

/* Loading 旋转指示器 */
.custom-toast-loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(212, 178, 140, 0.2);
  border-left-color: var(--theme-color);
  border-radius: 50%;
  animation: custom-toast-spin 0.8s linear infinite;
  display: block;
}

@keyframes custom-toast-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 自定义主题色对话框 */
.custom-dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(47, 62, 70, 0.4);
  backdrop-filter: blur(8rpx);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: maskFadeIn 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.custom-dialog-box {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  width: 85%;
  max-width: 600rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border);
  text-align: center;
  animation: customScaleIn 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes customScaleIn {
  from { transform: scale(0.9); }
  to { transform: scale(1); }
}

.custom-dialog-icon-wrap {
  margin-bottom: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background: var(--gold-light);
  border-radius: 50%;
}

.custom-dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.custom-dialog-content {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  padding: 0 24rpx;
  margin-bottom: 40rpx;
  white-space: pre-wrap;
}

.custom-dialog-footer {
  display: flex;
  gap: 20rpx;
  padding: 0 16rpx;
}

.custom-dialog-footer button {
  flex: 1;
  font-size: 28rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  border-radius: var(--radius-sm);
  margin: 0;
  padding: 0;
}

.custom-dialog-btn-cancel {
  border: 1rpx solid var(--border) !important;
  background: #FFFFFF !important;
  color: var(--text-muted) !important;
}

.custom-dialog-btn-confirm {
  background: var(--theme-color) !important;
  color: #FFFFFF !important;
  box-shadow: 0 6rpx 20rpx rgba(212, 178, 140, 0.12) !important;
  border: none !important;
}

/* 字数计数器 */
.textarea-container {
  position: relative;
  width: 100%;
}

.word-counter {
  position: absolute;
  right: 24rpx;
  bottom: 12rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  pointer-events: none;
  z-index: 10;
}

/* 通用多行输入框 */
.textarea-field {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 28rpx 48rpx 28rpx;
  background: #FDFDFB;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-main);
  transition: var(--transition);
}

.textarea-field:focus {
  border-color: var(--gold);
}
