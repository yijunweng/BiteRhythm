/** miniprogram/app.wxss **/

/* 全局设计变量 */
page {
  --primary-color: #6C8EBF;        /* 莫兰迪雾霾蓝 */
  --primary-light: #E8EEF5;       /* 浅雾霾蓝 */
  --accent-color: #E29B9B;         /* 莫兰迪烟粉色 */
  --accent-light: #F9ECEC;         /* 浅烟粉色 */
  --green-color: #9BB8A7;          /* 莫兰迪灰绿 */
  --green-light: #ECF2EE;          /* 浅灰绿 */
  --bg-color: #F6F8FC;             /* 极简灰白背景 */
  --card-bg: rgba(255, 255, 255, 0.85); /* 磨砂玻璃卡片背景 */
  --card-border: rgba(255, 255, 255, 0.5);
  --shadow-color: rgba(108, 142, 191, 0.08);
  --shadow-hover: rgba(108, 142, 191, 0.15);
  
  --text-main: #333C48;            /* 深烟灰 */
  --text-sub: #7A869A;             /* 灰蓝 */
  --text-light: #B3BAC5;           /* 浅灰 */
  
  background-color: var(--bg-color);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 统一重置 */
view, text, scroll-view, input, button, textarea, label {
  box-sizing: border-box;
}

/* 渐变背景底层 */
.app-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #EBF0F6 0%, #F6F8FC 30%, #F6F8FC 100%);
  padding: 30rpx;
  padding-bottom: 80rpx;
}

/* 磨砂玻璃卡片容器 */
.glass-card {
  background: var(--card-bg);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid var(--card-border);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 36rpx var(--shadow-color);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.glass-card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 48rpx var(--shadow-hover);
  border-color: rgba(255, 255, 255, 0.8);
}

/* 莫兰迪风格主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #7FA2D4 0%, #6C8EBF 100%);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-weight: 600;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(108, 142, 191, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-primary-hover {
  opacity: 0.95;
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(108, 142, 191, 0.2);
}

/* 莫兰迪风格次按钮 */
.btn-secondary {
  background: var(--primary-light);
  color: var(--primary-color);
  border-radius: 24rpx;
  font-weight: 600;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  border: 1rpx solid rgba(108, 142, 191, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-secondary-hover {
  background: rgba(108, 142, 191, 0.15);
  transform: scale(0.98);
}

/* 危险/警告按钮 */
.btn-danger {
  background: var(--accent-light);
  color: var(--accent-color);
  border-radius: 24rpx;
  font-weight: 600;
  font-size: 30rpx;
  padding: 24rpx 48rpx;
  border: 1rpx solid rgba(226, 155, 155, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-danger-hover {
  background: rgba(226, 155, 155, 0.25);
  transform: scale(0.98);
}

/* 输入框通用样式 */
.custom-input {
  width: 100%;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(108, 142, 191, 0.15);
  border-radius: 20rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: var(--text-main);
  transition: all 0.3s ease;
}

.custom-input:focus {
  border-color: var(--primary-color);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 0 12rpx rgba(108, 142, 191, 0.1);
}

/* 标签样式 */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.badge-primary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.badge-accent {
  background-color: var(--accent-light);
  color: var(--accent-color);
}

.badge-green {
  background-color: var(--green-light);
  color: var(--green-color);
}

/* 无内容占位 */
.empty-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-light);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 30rpx;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  background: linear-gradient(to bottom, var(--primary-color), var(--accent-color));
}

/* 列表淡入动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeIn 0.5s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
}
