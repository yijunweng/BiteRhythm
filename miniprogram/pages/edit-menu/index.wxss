/* miniprogram/pages/edit-menu/index.wxss */

.edit-container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 顶部信息 */
.header-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.date-badge {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  background: var(--card-bg);
  padding: 12rpx 30rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--card-border);
}

/* 已添加列表 */
.dish-list-card {
  margin-bottom: 30rpx;
}

.current-dishes {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.edit-dish-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.4);
  border: 1rpx solid rgba(108,142,191,0.08);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  animation: fadeIn 0.3s ease;
}

.dish-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dish-label {
  font-size: 28rpx;
  font-weight: 600;
}

.btn-remove {
  font-size: 36rpx;
  color: var(--accent-color);
  padding: 0 10rpx;
}

/* 手动添加输入面板 */
.add-panel {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.input-box {
  flex: 1;
}

.category-picker {
  width: 160rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(108, 142, 191, 0.15);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-main);
  height: 90rpx;
}

.btn-add-circle {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #7FA2D4 0%, #6C8EBF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(108, 142, 191, 0.2);
}

/* AI智能卡片与魔幻呼吸灯效果 */
.ai-helper-card {
  border: 2rpx solid rgba(155, 184, 167, 0.3);
  position: relative;
  overflow: hidden;
}

.ai-helper-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  background: linear-gradient(135deg, rgba(155, 184, 167, 0.4), rgba(108, 142, 191, 0.4)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.7;
}

.ai-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ai-logo {
  font-size: 36rpx;
}

.ai-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--green-color);
}

.ai-desc {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-bottom: 30rpx;
}

/* AI 推荐结果展示 */
.ai-recommend-box {
  background: rgba(155, 184, 167, 0.08);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  border: 1rpx dashed rgba(155, 184, 167, 0.3);
  animation: fadeIn 0.4s ease;
}

.ai-recommend-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--green-color);
  margin-bottom: 20rpx;
}

.ai-recommend-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(155, 184, 167, 0.1);
}

.ai-recommend-item:last-child {
  border-bottom: none;
}

.ai-dish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ai-dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.ai-dish-reason {
  font-size: 22rpx;
  color: var(--text-sub);
  margin-top: 8rpx;
  font-style: italic;
}

.ai-btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

/* 遮罩及弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(51, 60, 72, 0.4);
  backdrop-filter: blur(10px);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #F6F8FC;
  width: 100%;
  max-height: 80vh;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
}

.modal-close {
  font-size: 44rpx;
  color: var(--text-light);
  padding: 0 10rpx;
}

/* 弹窗搜索框 */
.modal-search {
  margin-bottom: 30rpx;
}

/* 分类过滤器小药丸 */
.modal-filter-pills {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.filter-pill {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(0,0,0,0.05);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}

.filter-pill.active {
  background: var(--primary-light);
  color: var(--primary-color);
  border-color: rgba(108,142,191,0.2);
  font-weight: 600;
}

/* 候选菜品滚动列表 */
.modal-scroll-list {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 30rpx;
}

.repo-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0,0,0,0.02);
}

.repo-item-name {
  font-size: 28rpx;
  font-weight: 500;
}

.btn-repo-add {
  font-size: 24rpx;
  background: var(--primary-light);
  color: var(--primary-color);
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

/* 底部主保存按钮 */
.save-btn-bar {
  margin-top: 40rpx;
  display: flex;
  gap: 20rpx;
}

.save-btn-bar button {
  flex: 1;
}
