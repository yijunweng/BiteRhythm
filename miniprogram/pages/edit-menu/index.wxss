/* miniprogram/pages/edit-menu/index.wxss */

.edit-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-top: 24rpx;
  padding-bottom: 0 !important;
  box-sizing: border-box;
}

.edit-scroll-area {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.edit-bottom-bar {
  width: 100%;
  padding: 24rpx 0 calc(24rpx + env(safe-area-inset-bottom)) 0;
  background: var(--bg);
  border-top: 1rpx solid var(--border);
}

/* 日期标题 */
.edit-date-header {
  margin-bottom: 32rpx;
  padding: 0 4rpx;
}

.edit-date-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 6rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.edit-date-sub {
  font-size: 24rpx;
  color: var(--text-muted);
}

.menu-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx !important;
}

.menu-card .empty-state {
  flex: 1;
  padding: 40rpx 0;
}

/* 菜品列表 */
.edit-dish-list {
  margin-bottom: 12rpx;
}

.edit-dish-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.edit-dish-row:last-child {
  border-bottom: none;
}

.edit-dish-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.dish-category-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}

.edit-dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  flex: 1;
}

.edit-dish-cat {
  font-size: 22rpx;
  color: var(--text-muted);
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.delete-btn {
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #E53935;
  flex-shrink: 0;
  padding: 8rpx;
}

/* 添加输入行 */
.add-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.add-input {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
}

.cat-picker-btn {
  height: 80rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-main);
  white-space: nowrap;
  transition: var(--transition);
  box-sizing: border-box;
}

.cat-picker-btn.active {
  border-color: var(--theme-color);
  background: #FFFFFF;
  color: var(--theme-color);
  box-shadow: 0 0 0 3rpx rgba(214, 178, 140, 0.15);
}

.add-circle-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--theme-color);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
  flex-shrink: 0;
}

/* 快捷操作按钮组 */
.quick-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-quick {
  width: 100% !important;
  margin: 0 !important;
  background: #FFFFFF;
  color: var(--text-main);
  border: 1rpx solid var(--border);
  padding: 20rpx 0 !important;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  line-height: 1;
}

.btn-quick-hover {
  background: #FAF7F2;
  border-color: var(--gold);
}

.btn-clear {
  color: #E53935;
  border-color: #FFEBEE;
  background: #FFF8F8;
}

/* AI 卡片 */
.ai-card {
  border-left: 6rpx solid var(--gold);
  background: linear-gradient(135deg, #FDFCF9 0%, #FAF6EE 100%);
}

.ai-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ai-star {
  font-size: 28rpx;
  color: var(--gold);
  font-weight: bold;
}

.ai-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.ai-card-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.ai-result-panel {
  margin-top: 24rpx;
}

.ai-result-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 16rpx;
}

.ai-result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ai-result-item {
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
}

.ai-result-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.ai-result-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.ai-result-cat {
  font-size: 22rpx;
  color: var(--text-muted);
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.ai-result-reason {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
  font-style: italic;
}

.ai-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* 保存按钮 */
.save-btn {
  width: 100% !important;
  margin: 0 !important;
}

/* 菜品库弹窗 */
.filter-pills-row {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.filter-pill {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  margin-right: 12rpx;
  white-space: nowrap;
}

.filter-pill.active {
  background: var(--text-main);
  color: #FFFFFF;
  border-color: var(--text-main);
}

.repo-scroll {
  height: 600rpx;
}

.repo-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.repo-item:last-child {
  border-bottom: none;
}

.repo-item-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.repo-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.repo-item-cat {
  font-size: 22rpx;
  color: var(--text-muted);
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.repo-add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--gold-light);
  color: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 骨架屏组件样式 */
.skeleton-date-header {
  pointer-events: none;
}

.skeleton-date-title-placeholder {
  width: 260rpx;
  height: 48rpx;
  margin-bottom: 12rpx !important;
}

.skeleton-date-sub-placeholder {
  width: 160rpx;
  height: 32rpx;
  margin-bottom: 0 !important;
}

.skeleton-menu-card {
  pointer-events: none;
}

.skeleton-section-title {
  width: 180rpx;
  height: 42rpx;
  margin-bottom: 24rpx !important;
}

.skeleton-dish-row {
  border-bottom: 1rpx solid var(--border);
  padding: 24rpx 0;
  pointer-events: none;
}

.skeleton-dish-cat {
  width: 80rpx;
  height: 32rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-dish-name {
  width: 220rpx;
  height: 36rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-add-input-row {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  align-items: center;
}

.skeleton-cat-btn {
  width: 130rpx;
  height: 80rpx;
  border-radius: var(--radius-sm) !important;
  margin-bottom: 0 !important;
}

.skeleton-input {
  flex: 1;
  height: 80rpx;
  border-radius: var(--radius-sm) !important;
  margin-bottom: 0 !important;
}

.skeleton-add-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50% !important;
  margin-bottom: 0 !important;
}

.skeleton-repo-btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-sm) !important;
  margin-bottom: 24rpx !important;
}

.skeleton-quick-btns {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-quick-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-sm) !important;
  margin-bottom: 0 !important;
}

.skeleton-ai-card {
  pointer-events: none;
}

.skeleton-ai-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.skeleton-ai-star {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50% !important;
  margin-bottom: 0 !important;
}

.skeleton-ai-title {
  width: 240rpx;
  height: 40rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-ai-desc {
  width: 100%;
  height: 32rpx;
  border-radius: 8rpx !important;
  margin-bottom: 24rpx !important;
}

.skeleton-ai-btn {
  width: 100%;
  height: 84rpx;
  border-radius: var(--radius-sm) !important;
  margin-bottom: 0 !important;
}

/* 顶部已选菜品卡片头部动作组 */
.menu-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.menu-card-header .section-title {
  margin-bottom: 0;
}

.menu-header-actions {
  display: flex;
  gap: 24rpx;
}

.action-text-btn {
  font-size: 26rpx;
  color: var(--gold);
  font-weight: 600;
  padding: 8rpx 0;
}

.action-text-btn.btn-clear-text {
  color: #E53935;
}

