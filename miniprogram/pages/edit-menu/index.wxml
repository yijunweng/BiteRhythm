<!-- miniprogram/pages/edit-menu/index.wxml -->
<view class="page-container edit-page">

  <!-- 骨架屏加载状态 -->
  <block wx:if="{{ loading }}">
    <!-- 日期标题骨架 -->
    <view class="edit-date-header skeleton-date-header">
      <view class="shimmer-line skeleton-date-title-placeholder"></view>
      <view class="shimmer-line skeleton-date-sub-placeholder"></view>
    </view>

    <!-- 今日已选菜品卡片骨架 -->
    <view class="card menu-card skeleton-menu-card">
      <view class="shimmer-line skeleton-section-title"></view>
      
      <!-- 菜品列表骨架 -->
      <view class="edit-dish-list">
        <view class="edit-dish-row skeleton-dish-row" wx:for="{{ 3 }}" wx:key="index">
          <view class="edit-dish-left">
            <view class="shimmer-line skeleton-dish-cat"></view>
            <view class="shimmer-line skeleton-dish-name"></view>
          </view>
        </view>
      </view>

      <!-- 快捷添加输入区骨架 -->
      <view class="add-input-row skeleton-add-input-row" wx:if="{{ !isReadOnly }}">
        <view class="shimmer-line skeleton-cat-btn"></view>
        <view class="shimmer-line skeleton-input"></view>
        <view class="shimmer-line skeleton-add-circle"></view>
      </view>
    </view>

    <!-- 操作按钮区骨架 -->
    <view wx:if="{{ !isReadOnly }}">
      <view class="shimmer-line skeleton-repo-btn"></view>
      <view class="quick-btns skeleton-quick-btns">
        <view class="shimmer-line skeleton-quick-btn"></view>
        <view class="shimmer-line skeleton-quick-btn"></view>
      </view>
    </view>

    <!-- AI 推荐卡片骨架 -->
    <view class="card ai-card skeleton-ai-card" wx:if="{{ !isReadOnly }}">
      <view class="ai-card-header skeleton-ai-header">
        <view class="shimmer-line skeleton-ai-star"></view>
        <view class="shimmer-line skeleton-ai-title"></view>
      </view>
      <view class="shimmer-line skeleton-ai-desc"></view>
      <view class="shimmer-line skeleton-ai-btn"></view>
    </view>
  </block>

  <block wx:else>
    <!-- 日期标题 -->
    <view class="edit-date-header">
      <text class="edit-date-title">🗓 {{ dateStr }}</text>
      <text class="edit-date-sub">今日菜单编辑</text>
    </view>

    <!-- 只读提示条 -->
    <view class="read-only-banner" wx:if="{{ isReadOnly }}">
      🔒 您当前是只读角色，可浏览菜单但无法修改
    </view>

    <!-- 当日已选菜品卡片 -->
    <view class="card menu-card">
      <view class="section-title">今日菜谱</view>

      <!-- 菜品列表 -->
      <scroll-view class="edit-dish-list" scroll-y="true" wx:if="{{ dishesList.length > 0 }}">
        <view class="edit-dish-row" wx:for="{{ dishesList }}" wx:key="index">
          <view class="edit-dish-left">
            <text class="edit-dish-cat">{{ item.category || '热菜' }}</text>
            <text class="edit-dish-name">{{ item.name }}</text>
          </view>
          <view class="delete-btn" bindtap="onRemoveDish" data-index="{{ index }}" wx:if="{{ !isReadOnly }}">
            <text>✕</text>
          </view>
        </view>
      </scroll-view>

      <!-- 空状态 -->
      <view class="empty-state" wx:else>
        <view class="empty-icon">🍲</view>
        <view class="empty-text">今天吃什么？快来添加吧！</view>
      </view>

      <!-- 快捷添加输入区（只读时隐藏） -->
      <view class="add-input-row" wx:if="{{ !isReadOnly }}">
        <picker bindchange="onCategoryChange" value="{{ categoryIndex }}" range="{{ categories }}">
          <view class="cat-picker-btn">{{ customDishCategory }} ▾</view>
        </picker>
        <input
          class="input-field add-input"
          placeholder="输入新菜名..."
          value="{{ customDishName }}"
          bindinput="onCustomDishInput"
          confirm-type="done"
          bindconfirm="onAddCustomDish"
        />
        <view class="add-circle-btn" bindtap="onAddCustomDish">＋</view>
      </view>
    </view>

    <!-- 操作按钮区（只读时隐藏） -->
    <view wx:if="{{ !isReadOnly }}">
      <!-- 从菜品库选择 -->
      <button
        class="btn-secondary"
        hover-class="btn-secondary-hover"
        bindtap="onOpenRepository"
        style="margin-bottom: 24rpx;"
      >
        📖 从收藏菜品库选择
      </button>

      <!-- 快捷操作 -->  
      <view class="quick-btns">
        <button class="btn-quick" hover-class="btn-quick-hover" bindtap="onCopyYesterdayMenu">
          📋 复制昨日
        </button>
        <button class="btn-quick btn-clear" hover-class="btn-quick-hover" bindtap="onClearMenu">
          🗑 清空菜单
        </button>
      </view>
    </view>

    <!-- AI 智能搞配卡片（只读时隐藏） -->
    <view class="card ai-card" wx:if="{{ !isReadOnly }}">
      <view class="ai-card-header">
        <text class="ai-star">✦</text>
        <text class="ai-card-title">AI 智能搞配助理</text>
      </view>
      <view class="ai-card-desc">根据家庭唇好、忌口和最近吃过的菜，自动推荐最合适的今日搞配。</view>

      <!-- 调用按钮 -->
      <button
        class="btn-primary"
        hover-class="btn-primary-hover"
        bindtap="onCallAIRecommend"
        disabled="{{ aiLoading }}"
        wx:if="{{ !showAiPanel }}"
        style="margin-top: 24rpx;"
      >
        🪴 {{ aiLoading ? 'AI 思考中...' : 'AI 一键推荐搞配' }}
      </button>

      <!-- AI 推荐结果面板 -->
      <view class="ai-result-panel" wx:if="{{ showAiPanel }}">
        <!-- 加载状态 -->
        <view class="ai-loading-wrap" wx:if="{{ aiLoading }}">
          <view class="spinner"></view>
          <text>AI 正在为您配菜，请稍候...</text>
        </view>

        <!-- 推荐结果列表 -->
        <block wx:else>
          <view class="ai-result-title">💡 AI 推荐配餐成果：</view>
          <view class="ai-rec-list">
            <view class="ai-rec-item" wx:for="{{ aiRecommendations }}" wx:key="index">
              <view class="ai-rec-info">
                <text class="ai-rec-cat">{{ item.category }}</text>
                <text class="ai-rec-name">{{ item.name }}</text>
              </view>
              <button class="btn-add-rec" size="mini" bindtap="onAddAiRecommendedDish" data-dish="{{ item }}">添加</button>
            </view>
          </view>
          <view class="ai-rec-actions">
            <button class="btn-primary" size="mini" bindtap="onApplyAllRecommendations">一键应用全部</button>
            <button class="btn-secondary" size="mini" bindtap="onCallAIRecommend">换一换</button>
          </view>
        </block>
      </view>
    </view>

    <!-- 保存按钮（只读时隐藏） -->
    <button
      class="btn-primary save-btn"
      hover-class="btn-primary-hover"
      bindtap="onSaveMenu"
      disabled="{{ saving }}"
      wx:if="{{ !isReadOnly }}"
      style="margin-top: 32rpx;"
    >
      {{ saving ? '保存中...' : '确认并保存菜单' }}
    </button>

    <!-- 从菜品库选择 Modal -->
    <view class="modal-mask" wx:if="{{ showRepositoryModal }}" bindtap="onCloseRepository">
      <view class="modal-sheet" catchtap="noop">
        <view class="modal-header">
          <text class="modal-title">📖 从收藏菜品库选择</text>
          <view class="modal-close" bindtap="onCloseRepository">×</view>
        </view>

        <!-- 搜索与筛选 -->
        <view class="search-bar">
          <input
            class="input-field search-input"
            placeholder="🔍 输入关键字搜索..."
            value="{{ searchKeyword }}"
            bindinput="onSearchInput"
          />
        </view>

        <!-- 类别 Filter -->
        <scroll-view class="repo-cat-scroll" scroll-x="true">
          <view
            class="repo-cat-pill {{ selectedRepoCategory === item ? 'active' : '' }}"
            wx:for="{{ repoCategories }}"
            wx:key="index"
            bindtap="onSelectCategoryFilter"
            data-category="{{ item }}"
          >
            {{ item }}
          </view>
        </scroll-view>

        <!-- 菜品列表 -->
        <scroll-view class="repo-scroll" scroll-y="true">
          <view class="repo-item" wx:for="{{ filteredRepoDishes }}" wx:key="_id">
            <view class="repo-item-info">
              <text class="repo-item-name">{{ item.name }}</text>
              <text class="repo-item-cat">{{ item.category }}</text>
            </view>
            <view class="repo-add-btn" bindtap="onAddRepoDish" data-dish="{{ item }}">＋</view>
          </view>
          <view class="empty-state" wx:if="{{ filteredRepoDishes.length === 0 }}">
            <view class="empty-text">没有找到符合条件的菜品</view>
          </view>
        </scroll-view>
      </view>
    </view>
  </block>

</view>
