<!-- miniprogram/pages/edit-menu/index.wxml -->
<view class="page-container edit-page">

  <!-- 骨架屏加载状态 -->
  <block wx:if="{{ loading }}">
    <scroll-view class="edit-scroll-area" scroll-y="true">
      <!-- 日期标题骨架 -->
      <view class="edit-date-header skeleton-date-header">
        <view class="shimmer-line skeleton-date-title-placeholder"></view>
      </view>

      <!-- 今日已选菜品卡片骨架 -->
      <view class="card menu-card skeleton-menu-card">
        <view class="shimmer-line skeleton-section-title"></view>
        
        <!-- 菜品列表骨架 -->
        <view class="edit-dish-list">
          <view class="edit-dish-row skeleton-dish-row" wx:for="{{ 3 }}" wx:key="index">
            <view class="edit-dish-left">
              <view class="shimmer-line skeleton-dish-cat"></view>
              <view class="shimmer-line skeleton-dish-name"></view>
            </view>
          </view>
        </view>

        <!-- 快捷添加输入区骨架 -->
        <view class="add-input-row skeleton-add-input-row" wx:if="{{ !isReadOnly }}">
          <view class="shimmer-line skeleton-cat-btn"></view>
          <view class="shimmer-line skeleton-input"></view>
          <view class="shimmer-line skeleton-add-circle"></view>
        </view>
      </view>

      <!-- 操作按钮区骨架 -->
      <view wx:if="{{ !isReadOnly }}">
        <view class="shimmer-line skeleton-repo-btn"></view>
      </view>

      <!-- AI 推荐卡片骨架 -->
      <view class="card ai-card skeleton-ai-card" wx:if="{{ !isReadOnly }}">
        <view class="ai-card-header skeleton-ai-header">
          <view class="shimmer-line skeleton-ai-star"></view>
          <view class="shimmer-line skeleton-ai-title"></view>
        </view>
        <view class="shimmer-line skeleton-ai-desc"></view>
        <view class="shimmer-line skeleton-ai-btn"></view>
      </view>
    </scroll-view>
  </block>

  <block wx:else>
    <!-- 上方滚动区域 -->
    <scroll-view class="edit-scroll-area" scroll-y="true">
      <!-- 日期标题 -->
      <view class="edit-date-header">
        <view class="edit-date-title">
          <text class="iconfont iconfont-calendar"></text>
          <text>{{ dateStr }}</text>
        </view>
      </view>

      <!-- 只读提示条 -->
      <view class="read-only-banner" wx:if="{{ isReadOnly }}">
        <text class="iconfont iconfont-lock"></text>
        <text>您当前是只读角色，可浏览菜单但无法修改</text>
      </view>

      <!-- 当日已选菜品卡片 -->
      <view class="card menu-card">
        <view class="menu-card-header">
          <view class="section-title">今日菜谱</view>
          <view class="menu-header-actions" wx:if="{{ !isReadOnly }}">
            <text class="btn-text-theme" bindtap="onCopyYesterdayMenu">复制昨日菜谱</text>
            <text class="btn-danger-text" bindtap="onClearMenu">清空</text>
          </view>
        </view>

        <!-- 菜品列表 -->
        <scroll-view class="edit-dish-list" scroll-y="true" wx:if="{{ dishesList.length > 0 }}">
          <view class="edit-dish-row" wx:for="{{ dishesList }}" wx:key="index">
            <view class="edit-dish-left">
              <text class="edit-dish-cat">{{ item.category || '热菜' }}</text>
              <text class="edit-dish-name">{{ item.name }}</text>
            </view>
            <view class="delete-btn" bindtap="onRemoveDish" data-index="{{ index }}" wx:if="{{ !isReadOnly }}">
              <text>✕</text>
            </view>
          </view>
        </scroll-view>

        <!-- 空状态 -->
        <view class="empty-state" wx:else>
          <view class="empty-icon iconfont iconfont-dish" style="font-size: 80rpx;"></view>
          <view class="empty-text">今天吃什么？快来添加吧！</view>
        </view>

        <!-- 快捷添加输入区（只读时隐藏） -->
        <view class="add-input-row" wx:if="{{ !isReadOnly }}">
          <view class="custom-select-container cat-select open-up">
            <view class="cat-picker-btn {{ showCategoryPicker ? 'active' : '' }}" bindtap="onToggleCategoryPicker">
              <text>{{ customDishCategory }}</text>
              <text class="iconfont iconfont-down-line select-arrow {{ showCategoryPicker ? 'open' : '' }}" style="margin-left: 6rpx; font-size: 20rpx;"></text>
            </view>
            <view class="custom-select-options cat-options {{ showCategoryPicker ? 'show' : '' }}">
              <view
                class="custom-select-option {{ categoryIndex === index ? 'selected' : '' }}"
                wx:for="{{ categories }}"
                wx:key="index"
                bindtap="onSelectCategory"
                data-index="{{ index }}"
              >
                <text>{{ item }}</text>
              </view>
            </view>
            <view class="custom-select-backdrop" wx:if="{{ showCategoryPicker }}" bindtap="onCloseCategoryPicker"></view>
          </view>
          <input
            class="input-field add-input"
            placeholder="输入新菜名..."
            value="{{ customDishName }}"
            bindinput="onCustomDishInput"
            confirm-type="done"
            bindconfirm="onAddCustomDish"
          />
          <view class="add-circle-btn" bindtap="onAddCustomDish"><text class="iconfont iconfont-add" style="font-size: 32rpx; line-height: 1;"></text></view>
        </view>
      </view>

      <!-- 操作按钮区（只读时隐藏） -->
      <view wx:if="{{ !isReadOnly }}">
        <!-- 从菜品库选择 -->
        <button
          class="btn-secondary"
          hover-class="btn-secondary-hover"
          bindtap="onOpenRepository"
          style="margin-bottom: 24rpx;"
        >
          从收藏菜品库选择
        </button>
      </view>

      <!-- AI 智能搭配卡片（只读时隐藏） -->
      <view class="card ai-card" wx:if="{{ !isReadOnly }}">
        <view class="ai-card-header">
          <text class="iconfont iconfont-ai ai-star"></text>
          <text class="ai-card-title">AI 智能搭配助理</text>
        </view>
        <view class="ai-card-desc">根据家庭偏好、忌口和最近吃过的菜，自动推荐最合适的今日搭配。</view>

        <!-- 调用按钮 -->
        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onCallAIRecommend"
          disabled="{{ aiLoading }}"
          style="margin-top: 24rpx;"
        >
          <text class="iconfont iconfont-ai"></text>
          <text>{{ aiLoading ? 'AI 思考中...' : 'AI 一键推荐搭配' }}</text>
        </button>
      </view>
    </scroll-view>

    <!-- 下方固定区域 -->
    <view class="edit-bottom-bar" wx:if="{{ !isReadOnly }}">
      <button
        class="btn-primary save-btn"
        hover-class="btn-primary-hover"
        bindtap="onSaveMenu"
        disabled="{{ saving }}"
      >
        {{ saving ? '保存中...' : '确认并保存菜谱' }}
      </button>
    </view>

    <!-- 菜品库选择弹窗 -->
    <view class="modal-mask" wx:if="{{ showRepositoryModal }}" bindtap="onCloseRepository">
      <view class="modal-sheet" catchtap="noop">
        <view class="modal-header">
          <text class="modal-title">我的菜品库</text>
          <view class="modal-close" bindtap="onCloseRepository">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <!-- 搜索 -->
        <input
          class="input-field"
          placeholder="搜索菜品..."
          value="{{ searchKeyword }}"
          bindinput="onSearchInput"
          style="margin-bottom: 24rpx;"
        />

        <!-- 分类过滤 -->
        <scroll-view class="filter-pills-row" scroll-x="true">
          <view
            class="filter-pill {{ selectedRepoCategory === item ? 'active' : '' }}"
            wx:for="{{ repoCategories }}"
            wx:key="index"
            bindtap="onSelectCategoryFilter"
            data-category="{{ item }}"
          >
            {{ item }}
          </view>
        </scroll-view>

        <!-- 菜品列表 -->
        <scroll-view class="repo-scroll" scroll-y="true">
          <view class="repo-item" wx:for="{{ filteredRepoDishes }}" wx:key="_id">
            <view class="repo-item-info">
              <text class="repo-item-cat">{{ item.category }}</text>
              <text class="repo-item-name">{{ item.name }}</text>
            </view>
            <view class="repo-add-btn" bindtap="onAddRepoDish" data-dish="{{ item }}">
              <text class="iconfont iconfont-add"></text>
            </view>
          </view>
          <view class="empty-state" wx:if="{{ filteredRepoDishes.length === 0 }}">
            <view class="empty-text">没有找到符合条件的菜品</view>
          </view>
        </scroll-view>
      </view>
    </view>
  </block>

  <!-- 清空确认 Modal -->
  <view class="modal-mask" wx:if="{{ showClearConfirm }}" bindtap="onCloseClearConfirm">
    <view class="modal-sheet" catchtap="noop" style="padding-bottom: 60rpx; text-align: center;">
      <view class="modal-header" style="border: none; padding-bottom: 0;">
        <view style="flex: 1;"></view>
        <view class="modal-close" bindtap="onCloseClearConfirm">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>
      <view style="margin-bottom: 24rpx; display: inline-block;">
        <text class="iconfont iconfont-info" style="font-size: 80rpx; color: #E53935;"></text>
      </view>
      <view style="font-size: 32rpx; font-weight: 700; color: var(--text-main); margin-bottom: 16rpx;">确认清空</view>
      <view style="font-size: 26rpx; color: var(--text-muted); line-height: 1.6; padding: 0 32rpx; margin-bottom: 40rpx;">确定要清空今日菜单吗？</view>
      <view style="display: flex; gap: 20rpx; padding: 0 32rpx;">
        <button class="btn-secondary" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;" bindtap="onCloseClearConfirm">取消</button>
        <button class="btn-primary" style="flex: 1; background: #E53935; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; box-shadow: none;" bindtap="onCommitClearMenu">确认清空</button>
      </view>
    </view>
  </view>

  <!-- 自定义 Toast & Loading -->
  <view class="custom-toast-backdrop" wx:if="{{ toastData.show }}" catchtap="noop" catchtouchmove="noop"></view>
  <view class="custom-toast {{ toastData.show ? 'show' : '' }}">
    <view class="custom-toast-content">
      <view class="custom-toast-loading-spinner" wx:if="{{ toastData.type === 'loading' }}"></view>
      <text class="iconfont iconfont-right custom-toast-icon success" wx:elif="{{ toastData.type === 'success' }}"></text>
      <text class="iconfont iconfont-info custom-toast-icon info" wx:elif="{{ toastData.type === 'info' }}"></text>
      <text class="custom-toast-title" wx:if="{{ toastData.title }}">{{ toastData.title }}</text>
    </view>
  </view>
</view>
