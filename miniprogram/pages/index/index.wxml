<!-- miniprogram/pages/index/index.wxml -->
<view class="page-container index-page">

  <!-- 骨架屏加载状态 -->
  <block wx:if="{{ initialLoading }}">
    <!-- 顶部栏骨架 -->
    <view class="family-bar skeleton-bar">
      <view class="shimmer-line skeleton-title-placeholder"></view>
      <view class="shimmer-line skeleton-badge-placeholder"></view>
    </view>

    <!-- 日历卡片骨架 -->
    <view class="card calendar-card skeleton-card">
      <view class="cal-header">
        <view class="shimmer-line skeleton-month-placeholder"></view>
        <view class="cal-nav">
          <view class="shimmer-line skeleton-nav-btn"></view>
          <view class="shimmer-line skeleton-nav-btn"></view>
        </view>
      </view>
      
      <!-- 静态星期表头 -->
      <view class="week-row">
        <view class="week-cell">日</view>
        <view class="week-cell">一</view>
        <view class="week-cell">二</view>
        <view class="week-cell">三</view>
        <view class="week-cell">四</view>
        <view class="week-cell">五</view>
        <view class="week-cell">六</view>
      </view>

      <!-- 35个日历方块骨架 -->
      <view class="cal-grid">
        <view class="shimmer-line skeleton-day" wx:for="{{ 35 }}" wx:key="index"></view>
      </view>
    </view>

    <!-- 今日菜谱详情卡片骨架 -->
    <view class="card today-card skeleton-card">
      <view class="today-card-header">
        <view class="shimmer-line skeleton-today-title"></view>
        <view class="shimmer-line skeleton-edit-link"></view>
      </view>
      
      <!-- 菜品药丸骨架 -->
      <view class="dish-pills">
        <view class="shimmer-line skeleton-dish-pill" style="width: 160rpx;"></view>
        <view class="shimmer-line skeleton-dish-pill" style="width: 200rpx;"></view>
        <view class="shimmer-line skeleton-dish-pill" style="width: 140rpx;"></view>
      </view>

      <!-- 排餐按钮骨架 -->
      <view class="shimmer-line skeleton-btn-placeholder"></view>
      <view class="shimmer-line skeleton-tip-placeholder"></view>
    </view>
  </block>

  <block wx:else>
    <!-- 顶部家庭选择器 -->
    <view class="family-bar">
      <view class="family-selector" bindtap="toggleFamilySelector">
        <text class="family-name">{{ activeFamily ? activeFamily.name : '创建家庭' }}</text>
        <text class="iconfont iconfont-down-line family-arrow {{ showFamilySelector ? 'open' : '' }}"></text>
      </view>
      <view class="role-chip" wx:if="{{ activeFamily }}">
        <text wx:if="{{ memberRole === 'admin' }}">管理员</text>
        <text wx:elif="{{ memberRole === 'write' }}">家人</text>
        <text wx:else>只读</text>
      </view>
    </view>

    <!-- 家庭下拉菜单 -->
    <view class="family-dropdown animate-in" wx:if="{{ showFamilySelector }}">
      <view
        class="family-drop-item {{ activeFamily && activeFamily._id === item._id ? 'active' : '' }}"
        wx:for="{{ families }}"
        wx:key="_id"
        bindtap="onSelectFamily"
        data-family="{{ item }}"
      >
        <view style="display: flex; align-items: center; gap: 12rpx;">
          <text>{{ item.name }}</text>
          <text class="check-mark" wx:if="{{ activeFamily && activeFamily._id === item._id }}">✓</text>
        </view>
        <text
          class="iconfont iconfont-delete"
          catchtap="onDeleteFamilyFromSwitcher"
          data-family-id="{{ item._id }}"
          data-family-name="{{ item.name }}"
          wx:if="{{ !(activeFamily && activeFamily._id === item._id) }}"
          style="font-size: 30rpx; color: #E53935; padding: 10rpx; margin-right: -10rpx;"
        ></text>
      </view>
      <view class="family-drop-item add-item" bindtap="onCreateFamily">
        <text class="iconfont iconfont-add"></text>
        <text>创建新家庭</text>
      </view>
    </view>

    <!-- 无家庭时的引导 -->
    <view class="card empty-guide animate-in" wx:if="{{ !activeFamily && !loading }}">
      <view class="empty-state">
        <view class="empty-icon iconfont iconfont-dish" style="font-size: 80rpx;"></view>
        <view class="empty-text">还没有家庭群组\n点击上方创建您的第一个家庭吧</view>
      </view>
      <button class="btn-primary" hover-class="btn-primary-hover" bindtap="onCreateFamily">
        <text class="iconfont iconfont-add"></text>
        <text>创建我的家庭</text>
      </button>
    </view>

    <!-- 日历卡片 -->
    <view class="card calendar-card animate-in" wx:if="{{ activeFamily }}">
      <view class="cal-header">
        <text class="cal-month">{{ currentYear }}年 {{ currentMonth }}月</text>
        <view class="cal-nav">
          <view class="cal-nav-btn" bindtap="onChangeMonth" data-direction="prev"><text class="iconfont iconfont-left-line"></text></view>
          <view class="cal-nav-btn" bindtap="onChangeMonth" data-direction="next"><text class="iconfont iconfont-right-line"></text></view>
        </view>
      </view>

      <!-- 星期表头 -->
      <view class="week-row">
        <view class="week-cell">日</view>
        <view class="week-cell">一</view>
        <view class="week-cell">二</view>
        <view class="week-cell">三</view>
        <view class="week-cell">四</view>
        <view class="week-cell">五</view>
        <view class="week-cell">六</view>
      </view>

      <!-- 日历网格 -->
      <view class="cal-grid">
        <view
          class="cal-day {{ !item.isCurrentMonth ? 'other-month' : '' }} {{ item.isToday ? 'today' : '' }} {{ item.isSelected ? 'selected' : '' }} {{ item.hasMenu ? 'has-menu' : '' }}"
          wx:for="{{ days }}"
          wx:key="index"
          bindtap="onSelectDate"
          data-datestr="{{ item.dateStr }}"
        >
          <text class="cal-day-num">{{ item.day }}</text>
          <view class="menu-dot" wx:if="{{ item.hasMenu }}"></view>
        </view>
      </view>
    </view>

    <!-- 今日菜谱详情卡片 -->
    <view class="card today-card animate-in" wx:if="{{ activeFamily }}">
      <view class="today-card-header">
        <text class="today-title">{{ selectedDateStr ? selectedDateStr + ' 菜单' : '今日菜单' }}</text>
        <view
          class="edit-link"
          bindtap="onGoToEditMenu"
          wx:if="{{ memberRole !== 'read' }}"
        >
          <text>{{ selectedDateMenu && selectedDateMenu.dishes.length > 0 ? '编辑' : '规划' }}</text>
          <text class="iconfont iconfont-right-line"></text>
        </view>
      </view>

      <!-- 已规划菜品 -->
      <view class="dish-pills" wx:if="{{ selectedDateMenu && selectedDateMenu.dishes.length > 0 }}">
        <view class="dish-pill" wx:for="{{ selectedDateMenu.dishes }}" wx:key="index">
          <text class="iconfont iconfont-dish"></text>
          <text>{{ item.name }}</text>
        </view>
      </view>

      <!-- 未规划 -->
      <view class="empty-state" wx:else>
        <view class="empty-text">暂无已规划菜品{{ memberRole === 'read' ? '，请等待管理员安排' : '，点击右上方规划' }}</view>
      </view>

      <!-- AI 智能周排餐（非只读可见） -->
      <view wx:if="{{ memberRole !== 'read' }}" style="margin-top: 32rpx;">
        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onWeekAIPlan"
          disabled="{{ aiPlanLoading }}"
        >
          <text class="iconfont iconfont-ai"></text>
          <text>{{ aiPlanLoading ? '排餐中...' : '智能排餐（下周5天）' }}</text>
        </button>
        <view class="ai-btn-tip">
          <text class="iconfont iconfont-info"></text>
          <text>提示：排餐范围为从明天开始顺延的 5 个工作日（避开周末）</text>
        </view>
      </view>

      <!-- 只读提示 -->
      <view class="read-only-tip" wx:else>
        <text class="iconfont iconfont-info"></text>
        <text>只读模式：您可浏览菜单，无法修改</text>
      </view>
    </view>

    <!-- 创建家庭 Modal -->
    <view class="modal-mask" wx:if="{{ showCreateFamilyModal }}" bindtap="onCloseCreateFamilyModal">
      <view class="modal-sheet" catchtap="noop" style="padding-bottom: 80rpx;">
        <view class="modal-header">
          <text class="modal-title">创建新家庭</text>
          <view class="modal-close" bindtap="onCloseCreateFamilyModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">家庭名称</text>
          <input
            class="input-field"
            placeholder="请输入家庭名称，如「温馨小家」"
            value="{{ newFamilyName }}"
            bindinput="onNewFamilyNameInput"
          />
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onCommitCreateFamily"
          style="margin-top: 16rpx;"
        >
          确认创建
        </button>
      </view>
    </view>

    <!-- 自定义 Toast & Loading -->
    <view class="custom-toast-backdrop" wx:if="{{ toastData.show }}" catchtap="noop" catchtouchmove="noop"></view>
    <view class="custom-toast {{ toastData.show ? 'show' : '' }}">
      <view class="custom-toast-content">
        <view class="custom-toast-loading-spinner" wx:if="{{ toastData.type === 'loading' }}"></view>
        <text class="iconfont iconfont-success custom-toast-icon success" wx:elif="{{ toastData.type === 'success' }}"></text>
        <text class="iconfont iconfont-info custom-toast-icon info" wx:elif="{{ toastData.type === 'info' }}"></text>
        <text class="custom-toast-title" wx:if="{{ toastData.title }}">{{ toastData.title }}</text>
      </view>
    </view>
  </block>

  <!-- 删除家庭确认 Modal（放页面最外层，不受 block 限制） -->
  <view class="modal-mask" wx:if="{{ showDeleteFamilyConfirm }}" bindtap="onCloseDeleteFamilyConfirm">
    <view class="modal-sheet" catchtap="noop" style="padding-bottom: 60rpx; text-align: center;">
      <view class="modal-header" style="border: none; padding-bottom: 0;">
        <view style="flex: 1;"></view>
        <view class="modal-close" bindtap="onCloseDeleteFamilyConfirm">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>
      <view style="margin-bottom: 24rpx; display: inline-block;">
        <text class="iconfont iconfont-info" style="font-size: 80rpx; color: #E53935;"></text>
      </view>
      <view style="font-size: 32rpx; font-weight: 700; color: var(--text-main); margin-bottom: 16rpx;">确认删除家庭</view>
      <view style="font-size: 26rpx; color: var(--text-muted); line-height: 1.6; padding: 0 32rpx; margin-bottom: 40rpx;">确定要解散并删除家庭「{{ deleteFamilyName }}」吗？此操作将永久清除该家庭下所有成员、菜品及排餐记录，且无法恢复！</view>
      <view style="display: flex; gap: 20rpx; padding: 0 32rpx;">
        <button class="btn-secondary" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;" bindtap="onCloseDeleteFamilyConfirm">取消</button>
        <button class="btn-primary" style="flex: 1; background: #E53935; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; box-shadow: none;" bindtap="onCommitDeleteFamily">确认删除</button>
      </view>
    </view>
  </view>

</view>

