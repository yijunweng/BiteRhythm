<!-- miniprogram/pages/index/index.wxml -->
<wxs module="iconMap">
  var getCategoryIcon = function(category) {
    if (category === '热菜') return 'iconfont-hot-dishes';
    if (category === '凉菜') return 'iconfont-cold-dishes';
    if (category === '汤品') return 'iconfont-soup';
    if (category === '主食') return 'iconfont-rice';
    return 'iconfont-dish';
  };
  module.exports = {
    getCategoryIcon: getCategoryIcon
  };
</wxs>
<page-meta page-style="{{ showShoppingDetailsModal || showCreateFamilyModal || showDeleteFamilyConfirm || showClearMenuConfirm || showConfigPromptModal ? 'overflow: hidden; height: 100vh;' : '' }}" />
<view class="page-container index-page">

  <!-- 骨架屏加载状态 -->
  <block wx:if="{{ initialLoading }}">
    <!-- 顶部栏骨架 -->
    <view class="family-bar skeleton-bar">
      <view class="shimmer-line skeleton-title-placeholder"></view>
      <view class="shimmer-line skeleton-badge-placeholder"></view>
    </view>

    <!-- 日历卡片骨架 -->
    <view class="card calendar-card skeleton-card">
      <view class="cal-header">
        <view class="shimmer-line skeleton-month-placeholder"></view>
        <view class="cal-nav">
          <view class="shimmer-line skeleton-nav-btn"></view>
          <view class="shimmer-line skeleton-nav-btn"></view>
        </view>
      </view>
      
      <!-- 静态星期表头 -->
      <view class="week-row">
        <view class="week-cell">日</view>
        <view class="week-cell">一</view>
        <view class="week-cell">二</view>
        <view class="week-cell">三</view>
        <view class="week-cell">四</view>
        <view class="week-cell">五</view>
        <view class="week-cell">六</view>
      </view>

      <!-- 35个日历方块骨架 -->
      <view class="cal-grid">
        <view class="shimmer-line skeleton-day" wx:for="{{ 35 }}" wx:key="index"></view>
      </view>
    </view>

    <!-- 今日菜谱详情卡片骨架 -->
    <view class="card today-card skeleton-card">
      <view class="today-card-header">
        <view class="shimmer-line skeleton-today-title"></view>
        <view class="shimmer-line skeleton-edit-link"></view>
      </view>
      
      <!-- 菜品药丸骨架 -->
      <view class="dish-pills">
        <view class="shimmer-line skeleton-dish-pill" style="width: 160rpx;"></view>
        <view class="shimmer-line skeleton-dish-pill" style="width: 200rpx;"></view>
        <view class="shimmer-line skeleton-dish-pill" style="width: 140rpx;"></view>
      </view>

      <!-- 排餐按钮骨架 -->
      <view class="shimmer-line skeleton-btn-placeholder"></view>
      <view class="shimmer-line skeleton-tip-placeholder"></view>
    </view>
  </block>

  <block wx:else>
    <!-- 顶部家庭选择器 -->
    <view class="family-bar">
      <view class="family-selector" bindtap="toggleFamilySelector">
        <text class="family-name">{{ activeFamily ? activeFamily.name : '创建家庭' }}</text>
        <text class="iconfont iconfont-down-line family-arrow {{ showFamilySelector ? 'open' : '' }}"></text>
      </view>
      <view class="family-header-right" wx:if="{{ activeFamily }}">
        <view class="dining-people-chip" wx:if="{{ activeFamily.ai_config && (activeFamily.ai_config.adults > 0 || activeFamily.ai_config.kids > 0) }}">
          <text wx:if="{{ activeFamily.ai_config.adults > 0 }}">{{ activeFamily.ai_config.adults }}成人</text>
          <text wx:if="{{ activeFamily.ai_config.adults > 0 && activeFamily.ai_config.kids > 0 }}"> </text>
          <text wx:if="{{ activeFamily.ai_config.kids > 0 }}">{{ activeFamily.ai_config.kids }}小孩</text>
        </view>
        <view class="header-action-btn" bindtap="onOpenPosterSelector">
          <text class="iconfont iconfont-ai" style="font-size: 26rpx; margin-right: 6rpx;"></text>
          <text style="font-size: 22rpx; font-weight: 600;">生成海报</text>
        </view>
      </view>
    </view>

    <!-- 家庭下拉菜单 -->
    <view class="family-dropdown animate-in" wx:if="{{ showFamilySelector }}">
      <view
        class="family-drop-item {{ activeFamily && activeFamily._id === item._id ? 'active' : '' }}"
        wx:for="{{ families }}"
        wx:key="_id"
        bindtap="onSelectFamily"
        data-family="{{ item }}"
      >
        <view style="display: flex; align-items: center; gap: 12rpx;">
          <text>{{ item.name }}</text>
          <text class="check-mark" wx:if="{{ activeFamily && activeFamily._id === item._id }}">✓</text>
        </view>
        <text
          class="iconfont iconfont-delete"
          catchtap="onDeleteFamilyFromSwitcher"
          data-family-id="{{ item._id }}"
          data-family-name="{{ item.name }}"
          wx:if="{{ !(activeFamily && activeFamily._id === item._id) }}"
          style="font-size: 30rpx; color: #E53935; padding: 10rpx; margin-right: -10rpx;"
        ></text>
      </view>
      <view class="family-drop-item add-item" bindtap="onCreateFamily">
        <text class="iconfont iconfont-add"></text>
        <text>创建新家庭</text>
      </view>
    </view>

    <!-- 无家庭时的引导 -->
    <view class="card empty-guide animate-in" wx:if="{{ !activeFamily && !loading }}">
      <view class="empty-state">
        <view class="empty-icon iconfont iconfont-dish" style="font-size: 80rpx;"></view>
        <view class="empty-text">还没有家庭群组\n点击上方创建您的第一个家庭吧</view>
      </view>
      <button class="btn-primary" hover-class="btn-primary-hover" bindtap="onCreateFamily">
        <text class="iconfont iconfont-add"></text>
        <text>创建我的家庭</text>
      </button>
    </view>

    <!-- 日历卡片 -->
    <view class="card calendar-card animate-in" wx:if="{{ activeFamily }}">
      <view class="cal-header">
        <text class="cal-month">{{ currentYear }}年 {{ currentMonth }}月</text>
        <view class="cal-nav">
          <view class="cal-nav-btn" bindtap="onChangeMonth" data-direction="prev"><text class="iconfont iconfont-left-line"></text></view>
          <view class="cal-nav-btn" bindtap="onChangeMonth" data-direction="next"><text class="iconfont iconfont-right-line"></text></view>
        </view>
      </view>

      <!-- 星期表头 -->
      <view class="week-row">
        <view class="week-cell">日</view>
        <view class="week-cell">一</view>
        <view class="week-cell">二</view>
        <view class="week-cell">三</view>
        <view class="week-cell">四</view>
        <view class="week-cell">五</view>
        <view class="week-cell">六</view>
      </view>

      <!-- 日历网格 -->
      <view class="cal-grid">
        <view
          class="cal-day {{ !item.isCurrentMonth ? 'other-month' : '' }} {{ item.isToday ? 'today' : '' }} {{ item.isSelected ? 'selected' : '' }} {{ item.hasMenu ? 'has-menu' : '' }}"
          wx:for="{{ days }}"
          wx:key="index"
          bindtap="onSelectDate"
          data-datestr="{{ item.dateStr }}"
        >
          <text class="cal-day-num">{{ item.day }}</text>
          <view class="menu-dot" wx:if="{{ item.hasMenu }}"></view>
        </view>
      </view>
    </view>

    <!-- 今日菜谱详情卡片 -->
    <view class="card today-card animate-in" wx:if="{{ activeFamily }}">
      <view class="today-card-header">
        <text class="today-title">{{ selectedDateStr ? selectedDateStr + ' 菜单' : '今日菜单' }}</text>
        <view class="header-actions" wx:if="{{ memberRole !== 'read' }}">
          <view
            class="clear-link"
            bindtap="onClearTodayMenu"
            wx:if="{{ selectedDateMenu && selectedDateMenu.dishes.length > 0 }}"
          >
            <text>清空</text>
          </view>
          <view
            class="edit-link"
            bindtap="onGoToEditMenu"
          >
            <text>{{ selectedDateMenu && selectedDateMenu.dishes.length > 0 ? '编辑' : '规划' }}</text>
            <text class="iconfont iconfont-right-line"></text>
          </view>
        </view>
      </view>

      <!-- 已规划菜品 -->
      <view class="dish-pills" wx:if="{{ selectedDateMenu && selectedDateMenu.dishes.length > 0 }}">
        <view class="dish-pill" wx:for="{{ selectedDateMenu.dishes }}" wx:key="index">
          <text class="iconfont {{ iconMap.getCategoryIcon(item.category) }}"></text>
          <text>{{ item.name }}</text>
        </view>
      </view>

      <!-- 未规划 -->
      <view class="empty-state" wx:else>
        <view class="empty-text">暂无已规划菜品{{ memberRole === 'read' ? '，请等待管理员安排' : '，点击右上方规划' }}</view>
      </view>

      <!-- 采购建议区域 (仅在有菜品时显示) -->
      <view class="shopping-section" wx:if="{{ selectedDateMenu && selectedDateMenu.dishes.length > 0 }}">
        <view class="shopping-section-header">
          <text class="shopping-section-title">采购建议</text>
          <view 
            class="regenerate-link" 
            bindtap="onGenerateShoppingList" 
            wx:if="{{ selectedDateMenu.shopping_list && memberRole !== 'read' }}"
          >
            <text class="iconfont iconfont-refresh" style="font-size: 24rpx; margin-right: 6rpx;"></text>
            <text>更新建议</text>
          </view>
        </view>

        <block wx:if="{{ selectedDateMenu.shopping_list }}">
          <view class="shopping-content-wrapper">
            <view class="shopping-content preview">
              <view class="md-container" style="padding-top: 0; padding-bottom: 0;">
                <block wx:for="{{ parsedSimpleShoppingList }}" wx:key="index">
                  <view wx:if="{{ item.type === 'h1' }}" class="md-h1" style="margin-top: 10rpx;">{{ item.text }}</view>
                  <view wx:elif="{{ item.type === 'h2' }}" class="md-h2" style="margin-top: 10rpx;">{{ item.text }}</view>
                  <view wx:elif="{{ item.type === 'h3' }}" class="md-h3" style="margin-top: 10rpx;">{{ item.text }}</view>
                  <view wx:elif="{{ item.type === 'bullet' }}" class="md-bullet">
                    <text class="md-bullet-dot">•</text>
                    <text class="md-bullet-text">{{ item.text }}</text>
                  </view>
                  <view wx:elif="{{ item.type === 'p' }}" class="md-p">{{ item.text }}</view>
                  <view wx:elif="{{ item.type === 'table' }}" class="md-table">
                    <view class="md-thead">
                      <view class="md-tr">
                        <view wx:for="{{ item.headers }}" wx:for-item="header" wx:key="index" class="md-th">{{ header }}</view>
                      </view>
                    </view>
                    <view class="md-tbody">
                      <view wx:for="{{ item.rows }}" wx:for-item="row" wx:key="index" class="md-tr">
                        <view wx:for="{{ row }}" wx:for-item="cell" wx:key="index" class="md-td">{{ cell }}</view>
                      </view>
                    </view>
                  </view>
                </block>
              </view>
            </view>
          </view>
          
          <view class="view-details-btn-container">
            <button class="btn-secondary view-details-btn" bindtap="onOpenShoppingDetails">
              <text>查看详情</text>
              <text class="iconfont iconfont-right-line" style="font-size: 24rpx; margin-left: 8rpx;"></text>
            </button>
          </view>

          <view class="shopping-notice">
            <text class="iconfont iconfont-info" style="font-size: 24rpx; margin-right: 8rpx;"></text>
            <text>提示：采购建议由 AI 自动估算，仅供参考，请根据建议适当调整。</text>
          </view>
        </block>
        <block wx:else>
          <view class="empty-shopping-section" wx:if="{{ memberRole !== 'read' }}">
            <button
              class="btn-primary btn-generate-shopping"
              hover-class="btn-primary-hover"
              bindtap="onGenerateShoppingList"
              disabled="{{ shoppingLoading }}"
            >
              <text class="iconfont iconfont-ai"></text>
              <text>{{ shoppingLoading ? '正在分析食材...' : '智能生成采购建议' }}</text>
            </button>
            <view class="shopping-notice center">
              <text class="iconfont iconfont-info" style="font-size: 24rpx; margin-right: 8rpx;"></text>
              <text>仅供参考，根据建议适当调整</text>
            </view>
          </view>
          <view class="read-only-tip" wx:else>
            <text class="iconfont iconfont-info"></text>
            <text>暂无采购建议，请等待管理员生成</text>
          </view>
        </block>
      </view>

      <!-- 只读提示 (无菜品时可见) -->
      <view class="read-only-tip" wx:elif="{{ memberRole === 'read' }}">
        <text class="iconfont iconfont-info"></text>
        <text>只读模式：您可浏览菜单，无法修改</text>
      </view>
    </view>

    <!-- 创建家庭 Modal -->
    <view class="modal-mask" wx:if="{{ showCreateFamilyModal }}" bindtap="onCloseCreateFamilyModal">
      <view class="modal-sheet" catchtap="noop" style="padding-bottom: 80rpx;">
        <view class="modal-header">
          <text class="modal-title">创建新家庭</text>
          <view class="modal-close" bindtap="onCloseCreateFamilyModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">家庭名称</text>
          <input
            class="input-field"
            placeholder="请输入家庭名称，如「温馨小家」"
            value="{{ newFamilyName }}"
            bindinput="onNewFamilyNameInput"
          />
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onCommitCreateFamily"
          style="margin-top: 16rpx;"
        >
          确认创建
        </button>
      </view>
    </view>

    <!-- 自定义 Toast & Loading -->
    <view class="custom-toast-backdrop" wx:if="{{ toastData.show && toastData.type === 'loading' }}" catchtap="noop" catchtouchmove="noop"></view>
    <view class="custom-toast {{ toastData.show ? 'show' : '' }}">
      <view class="custom-toast-content">
        <view class="custom-toast-loading-spinner" wx:if="{{ toastData.type === 'loading' }}"></view>
        <text class="iconfont iconfont-success custom-toast-icon success" wx:elif="{{ toastData.type === 'success' }}"></text>
        <text class="iconfont iconfont-info custom-toast-icon info" wx:elif="{{ toastData.type === 'info' }}"></text>
        <text class="custom-toast-title" wx:if="{{ toastData.title }}">{{ toastData.title }}</text>
      </view>
    </view>
  </block>

  <!-- 删除家庭确认 Modal（放页面最外层，不受 block 限制） -->
  <view class="modal-mask" wx:if="{{ showDeleteFamilyConfirm }}" bindtap="onCloseDeleteFamilyConfirm">
    <view class="modal-sheet" catchtap="noop" style="padding-bottom: 60rpx; text-align: center;">
      <view class="modal-header" style="border: none; padding-bottom: 0;">
        <view style="flex: 1;"></view>
        <view class="modal-close" bindtap="onCloseDeleteFamilyConfirm">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>
      <view style="margin-bottom: 24rpx; display: inline-block;">
        <text class="iconfont iconfont-info" style="font-size: 80rpx; color: #E53935;"></text>
      </view>
      <view style="font-size: 32rpx; font-weight: 700; color: var(--text-main); margin-bottom: 16rpx;">确认删除家庭</view>
      <view style="font-size: 26rpx; color: var(--text-muted); line-height: 1.6; padding: 0 32rpx; margin-bottom: 40rpx;">确定要解散并删除家庭「{{ deleteFamilyName }}」吗？此操作将永久清除该家庭下所有成员、菜品及排餐记录，且无法恢复！</view>
      <view style="display: flex; gap: 20rpx; padding: 0 32rpx;">
        <button class="btn-secondary" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;" bindtap="onCloseDeleteFamilyConfirm">取消</button>
        <button class="btn-primary" style="flex: 1; background: #E53935; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; box-shadow: none;" bindtap="onCommitDeleteFamily">确认删除</button>
      </view>
    </view>
  </view>

  <!-- 清空菜单确认 Modal -->
  <view class="modal-mask" wx:if="{{ showClearMenuConfirm }}" bindtap="onCloseClearMenuConfirm">
    <view class="modal-sheet" catchtap="noop" style="padding-bottom: 60rpx; text-align: center;">
      <view class="modal-header" style="border: none; padding-bottom: 0;">
        <view style="flex: 1;"></view>
        <view class="modal-close" bindtap="onCloseClearMenuConfirm">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>
      <view style="margin-bottom: 24rpx; display: inline-block;">
        <text class="iconfont iconfont-info" style="font-size: 80rpx; color: #E53935;"></text>
      </view>
      <view style="font-size: 32rpx; font-weight: 700; color: var(--text-main); margin-bottom: 16rpx;">确认清空菜单</view>
      <view style="font-size: 26rpx; color: var(--text-muted); line-height: 1.6; padding: 0 32rpx; margin-bottom: 40rpx;">确定要清空 {{ selectedDateStr }} 的菜单吗？该操作将清除当天的所有排餐，且无法恢复！</view>
      <view style="display: flex; gap: 20rpx; padding: 0 32rpx;">
        <button class="btn-secondary" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;" bindtap="onCloseClearMenuConfirm">取消</button>
        <button class="btn-primary" style="flex: 1; background: #E53935; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; box-shadow: none;" bindtap="onCommitClearMenu">确认清空</button>
      </view>
    </view>
  </view>

  <!-- 首次使用 AI 配置提示 Modal -->
  <view class="custom-dialog-mask" wx:if="{{ showConfigPromptModal }}" bindtap="onCloseConfigPrompt">
    <view class="custom-dialog-box" catchtap="noop">
      <view class="custom-dialog-icon-wrap">
        <text class="iconfont iconfont-ai" style="font-size: 64rpx; color: var(--gold);"></text>
      </view>
      <view class="custom-dialog-title">提示</view>
      <view class="custom-dialog-content">首次使用 AI 功能前，请先完成家庭用餐人数及偏好配置。</view>
      <view class="custom-dialog-footer">
        <button class="custom-dialog-btn-cancel" bindtap="onCloseConfigPrompt">取消</button>
        <button class="custom-dialog-btn-confirm" bindtap="onGoToConfig">去配置</button>
      </view>
    </view>
  </view>

  <!-- 采购建议详情 Modal (支持 Markdown 渲染) -->
  <view class="modal-mask" wx:if="{{ showShoppingDetailsModal }}" bindtap="onCloseShoppingDetails">
    <view class="modal-sheet shopping-details-sheet" catchtap="noop">
      <view class="modal-header">
        <text class="modal-title">采购建议详情</text>
        <view class="modal-close" bindtap="onCloseShoppingDetails">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>
      
      <scroll-view class="shopping-details-scroll" scroll-y="true">
        <view class="md-container">
          <block wx:for="{{ parsedFullShoppingList }}" wx:key="index">
            <view wx:if="{{ item.type === 'h1' }}" class="md-h1">{{ item.text }}</view>
            <view wx:elif="{{ item.type === 'h2' }}" class="md-h2">{{ item.text }}</view>
            <view wx:elif="{{ item.type === 'h3' }}" class="md-h3">{{ item.text }}</view>
            <view wx:elif="{{ item.type === 'bullet' }}" class="md-bullet">
              <text class="md-bullet-dot">•</text>
              <text class="md-bullet-text">{{ item.text }}</text>
            </view>
            <view wx:elif="{{ item.type === 'p' }}" class="md-p">{{ item.text }}</view>
            <view wx:elif="{{ item.type === 'table' }}" class="md-table">
              <view class="md-thead">
                <view class="md-tr">
                  <view wx:for="{{ item.headers }}" wx:for-item="header" wx:key="index" class="md-th">{{ header }}</view>
                </view>
              </view>
              <view class="md-tbody">
                <view wx:for="{{ item.rows }}" wx:for-item="row" wx:key="index" class="md-tr">
                  <view wx:for="{{ row }}" wx:for-item="cell" wx:key="index" class="md-td">{{ cell }}</view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 生成海报的日期选择 Modal -->
  <view class="modal-mask" wx:if="{{ showPosterDateModal }}" bindtap="onClosePosterSelector">
    <view class="modal-sheet" catchtap="noop">
      <view class="modal-header">
        <view class="modal-title">
          <text class="iconfont iconfont-calendar"></text>
          <text>选择分享日期 (可多选)</text>
        </view>
        <view class="modal-close" bindtap="onClosePosterSelector">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>

      <!-- 日历日期多选网格 -->
      <view class="poster-calendar-box">
        <view class="cal-header">
          <text class="cal-month">{{ posterYear }}年 {{ posterMonth }}月</text>
          <view class="cal-nav">
            <view class="cal-nav-btn" bindtap="onChangePosterMonth" data-direction="prev"><text class="iconfont iconfont-left-line"></text></view>
            <view class="cal-nav-btn" bindtap="onChangePosterMonth" data-direction="next"><text class="iconfont iconfont-right-line"></text></view>
          </view>
        </view>

        <view class="week-row" style="margin-bottom: 12rpx;">
          <view class="week-cell">日</view>
          <view class="week-cell">一</view>
          <view class="week-cell">二</view>
          <view class="week-cell">三</view>
          <view class="week-cell">四</view>
          <view class="week-cell">五</view>
          <view class="week-cell">六</view>
        </view>

        <view class="cal-grid">
          <view
            class="cal-day {{ !item.isCurrentMonth ? 'other-month' : '' }} {{ item.isToday ? 'today' : '' }} {{ item.isSelected ? 'selected' : '' }} {{ item.hasMenu ? 'has-menu' : '' }}"
            wx:for="{{ posterDays }}"
            wx:key="index"
            bindtap="onTogglePosterDate"
            data-datestr="{{ item.dateStr }}"
          >
            <text class="cal-day-num">{{ item.day }}</text>
            <view class="menu-dot" wx:if="{{ item.hasMenu }}"></view>
          </view>
        </view>
      </view>

      <view class="modal-footer" style="margin-top: 32rpx;">
        <button class="btn-primary" bindtap="onGeneratePosterPreview" style="background: var(--gold) !important; color: #FFFFFF !important; box-shadow: none !important; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;">生成海报</button>
      </view>
    </view>
  </view>

  <!-- 海报预览 Modal -->
  <view class="modal-mask" wx:if="{{ showPosterPreviewModal }}" bindtap="onClosePosterPreview">
    <view class="modal-sheet" catchtap="noop" style="padding-bottom: 48rpx;">
      <view class="modal-header">
        <view class="modal-title">
          <text class="iconfont iconfont-dish"></text>
          <text>海报预览</text>
        </view>
        <view class="modal-close" bindtap="onClosePosterPreview">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>

      <!-- 预览滚动区域 -->
      <scroll-view class="poster-preview-scroll" scroll-y="true">
        <view class="poster-preview-content">
          <view class="poster-header">
            <view class="poster-title-main">BiteRhythm</view>
            <view class="poster-subtitle">FAMILY MENU POSTER</view>
            <view class="poster-divider"></view>
          </view>
          
          <view class="poster-date-section" wx:for="{{ posterDateData }}" wx:key="date">
            <view class="poster-date-header">
              <text class="poster-date-text">{{ item.date }}</text>
            </view>
            
            <view class="poster-dishes-list" wx:if="{{ item.dishes && item.dishes.length > 0 }}">
              <view class="poster-dish-item" wx:for="{{ item.dishes }}" wx:for-item="dish" wx:key="index">
                <view class="poster-dish-title-row">
                  <text class="poster-dish-category">{{ dish.category }}</text>
                  <text class="poster-dish-name">{{ dish.name }}</text>
                </view>
                <view class="poster-dish-detail" wx:if="{{ dish.practice }}">
                  <text class="poster-detail-label">做法：</text>
                  <text class="poster-detail-val">{{ dish.practice }}</text>
                </view>
                <view class="poster-dish-detail" wx:if="{{ dish.remark }}">
                  <text class="poster-detail-label">备注：</text>
                  <text class="poster-detail-val">{{ dish.remark }}</text>
                </view>
              </view>
            </view>
            <view class="poster-empty-state" wx:else>
              <text>当日无菜单</text>
            </view>
            <view class="poster-section-divider" wx:if="{{ index < posterDateData.length - 1 }}"></view>
          </view>
          
          <view class="poster-footer">
            <view class="poster-footer-tip">BiteRhythm 食之律动 | 记录家庭饮食习惯</view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer" style="margin-top: 32rpx; display: flex; gap: 20rpx;">
        <button class="btn-secondary" bindtap="onClosePosterPreview" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;">取消</button>
        <button class="btn-primary" bindtap="onSavePosterToLocal" style="flex: 1; background: var(--gold) !important; color: #FFFFFF !important; box-shadow: none !important; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;">保存到本地</button>
      </view>
    </view>
  </view>

  <!-- 用于生成海报导出的离屏 Canvas -->
  <canvas type="2d" id="posterCanvas" style="width: {{ canvasWidth }}px; height: {{ canvasHeight }}px; position: fixed; left: -9999px; top: -9999px;"></canvas>

</view>

