/* miniprogram/pages/index/index.wxss */

.index-page {
  padding-top: 24rpx;
}

/* 顶部家庭选择器栏 */
.family-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.family-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}

.family-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.family-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  transition: transform 0.25s ease;
  display: inline-block;
}

.family-arrow.open {
  transform: rotate(180deg);
}

.role-chip {
  background: var(--gold-light);
  color: var(--gold);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 下拉菜单 */
.family-dropdown {
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.family-drop-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border-bottom: 1rpx solid var(--border);
  font-weight: 500;
}

.family-drop-item:last-child {
  border-bottom: none;
}

.family-drop-item.active {
  color: var(--gold);
  font-weight: 700;
  background: var(--gold-light);
}

.family-drop-item.add-item {
  color: var(--gold);
  font-weight: 600;
  justify-content: center;
}

.check-mark {
  font-size: 28rpx;
  color: var(--gold);
}

/* 空引导卡片 */
.empty-guide {
  text-align: center;
  padding: 64rpx 32rpx;
}

/* 日历卡片 */
.calendar-card {
  padding: 32rpx;
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.cal-month {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.cal-nav {
  display: flex;
  gap: 16rpx;
}

.cal-nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--text-main);
  font-weight: bold;
}

/* 星期表头 */
.week-row {
  display: flex;
  margin-bottom: 12rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
}

/* 日历网格 */
.cal-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-day {
  width: 14.2857%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  cursor: pointer;
  background: #FAF8F5;
  margin: 3rpx 0;
}

.cal-day-num {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 1;
}

.cal-day.other-month {
  opacity: 0.25;
  background: transparent;
}

.cal-day.today .cal-day-num {
  color: var(--gold);
  font-weight: 800;
}

.cal-day.selected {
  background: var(--text-main);
}

.cal-day.selected .cal-day-num {
  color: #FFFFFF;
  font-weight: 700;
}

.cal-day.selected.today .cal-day-num {
  color: var(--gold);
}

/* 已配餐指示点 */
.menu-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--gold);
  position: absolute;
  bottom: 6rpx;
}

.cal-day.selected .menu-dot {
  background: #FFFFFF;
}

/* 今日菜单卡片 */
.today-card {
  border-left: 6rpx solid var(--gold);
}

.today-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.today-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.edit-link {
  font-size: 26rpx;
  color: var(--gold);
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: var(--gold-light);
  border-radius: 12rpx;
}

/* 菜品药丸标签 */
.dish-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.dish-pill {
  background: #FCFAF2;
  color: var(--text-main);
  border: 1rpx solid var(--border);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.read-only-tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  background: #FDFDFB;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
}

.ai-btn-tip {
  font-size: 22rpx;
  color: var(--text-muted);
  text-align: center;
  margin-top: 12rpx;
  display: block;
}

/* 骨架屏组件样式 */
.skeleton-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skeleton-title-placeholder {
  width: 180rpx;
  height: 48rpx;
  margin-bottom: 0 !important;
}

.skeleton-badge-placeholder {
  width: 120rpx;
  height: 38rpx;
  border-radius: 20rpx;
  margin-bottom: 0 !important;
}

.skeleton-card {
  pointer-events: none;
}

.skeleton-month-placeholder {
  width: 160rpx;
  height: 40rpx;
  margin-bottom: 0 !important;
}

.skeleton-nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50% !important;
  margin-bottom: 0 !important;
}

.skeleton-day {
  width: 14.2857%;
  aspect-ratio: 1;
  border-radius: 16rpx !important;
  margin: 3rpx 0;
  margin-bottom: 0 !important;
}

.skeleton-today-title {
  width: 200rpx;
  height: 40rpx;
  margin-bottom: 0 !important;
}

.skeleton-edit-link {
  width: 80rpx;
  height: 44rpx;
  border-radius: 12rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-dish-pill {
  height: 56rpx;
  border-radius: 40rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-btn-placeholder {
  width: 100%;
  height: 84rpx;
  border-radius: var(--radius-sm) !important;
  margin-top: 32rpx;
  margin-bottom: 0 !important;
}

.skeleton-tip-placeholder {
  width: 60%;
  height: 24rpx;
  margin: 16rpx auto 0 auto !important;
  margin-bottom: 0 !important;
}

