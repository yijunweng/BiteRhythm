/* miniprogram/pages/index/index.wxss */

.index-container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 顶部状态栏与家庭选择器 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.family-selector-wrapper {
  position: relative;
}

.family-selector-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--card-bg);
  backdrop-filter: blur(10px);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  font-weight: 600;
  color: var(--text-main);
  box-shadow: 0 4rpx 16rpx var(--shadow-color);
}

.arrow-icon {
  margin-left: 10rpx;
  font-size: 20rpx;
  transition: transform 0.3s ease;
}

.arrow-icon.open {
  transform: rotate(180deg);
}

.family-dropdown {
  position: absolute;
  top: 90rpx;
  left: 0;
  width: 320rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(108, 142, 191, 0.15);
  z-index: 100;
  padding: 16rpx 0;
  overflow: hidden;
  animation: fadeIn 0.2s ease forwards;
}

.family-item {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border-bottom: 1rpx solid rgba(0,0,0,0.03);
}

.family-item:last-child {
  border-bottom: none;
}

.family-item.active {
  color: var(--primary-color);
  font-weight: 600;
  background-color: var(--primary-light);
}

.btn-add-family {
  color: var(--accent-color);
  font-weight: 600;
  text-align: center;
}

/* 导航小药丸 */
.nav-pill-wrapper {
  display: flex;
  gap: 15rpx;
}

.nav-pill {
  padding: 14rpx 28rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid var(--card-border);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  transition: all 0.2s ease;
}

.nav-pill-active {
  background: var(--primary-light);
  color: var(--primary-color);
  border-color: rgba(108,142,191,0.3);
}

/* 日历区域 */
.calendar-card {
  padding: 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.month-btn-group {
  display: flex;
  gap: 20rpx;
}

.month-nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(108, 142, 191, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary-color);
  font-size: 28rpx;
  font-weight: bold;
}

/* 星期头部 */
.weeks-row {
  display: flex;
  margin-bottom: 20rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  font-weight: 600;
}

/* 日子网络 */
.days-grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 20rpx;
}

.day-cell {
  width: 14.28%; /* 7列等分 */
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-num-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  transition: all 0.2s ease;
}

/* 非本月日期变淡 */
.day-cell.other-month {
  opacity: 0.25;
}

/* 今天高亮 */
.day-cell.is-today .day-num-box {
  background-color: var(--accent-light);
  color: var(--accent-color);
  font-weight: 700;
}

/* 选中日期高亮 */
.day-cell.is-selected .day-num-box {
  background: linear-gradient(135deg, #7FA2D4 0%, #6C8EBF 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 16rpx rgba(108, 142, 191, 0.35);
  font-weight: 700;
}

/* 已配餐小绿点 */
.menu-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: var(--green-color);
  border-radius: 50%;
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 菜单详情区域 */
.menu-details-card {
  margin-top: 30rpx;
}

.date-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid rgba(108, 142, 191, 0.1);
  padding-bottom: 20rpx;
  margin-bottom: 24rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.role-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(155, 184, 167, 0.15);
  color: var(--green-color);
}

/* 菜品展示 */
.dishes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.5);
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(108, 142, 191, 0.08);
}

.dish-num {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
  margin-right: 20rpx;
}

.dish-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
  flex: 1;
}

.dish-tag {
  font-size: 22rpx;
  color: var(--text-sub);
  background: rgba(0,0,0,0.03);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 页面底部管理员及快捷导航 */
.quick-nav {
  margin-top: 40rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.nav-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  box-shadow: 0 8rpx 24rpx var(--shadow-color);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.nav-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.nav-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
}
