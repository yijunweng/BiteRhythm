/* miniprogram/pages/index/index.wxss */

.index-page {
  padding-top: 24rpx;
}

/* 顶部家庭选择器栏 */
.family-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.family-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}

.family-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.family-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  transition: transform 0.25s ease;
  display: inline-block;
}

.family-arrow.open {
  transform: rotate(180deg);
}

.dining-people-chip {
  background: var(--gold-light);
  color: var(--gold);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 下拉菜单 */
.family-dropdown {
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.family-drop-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-main);
  border-bottom: 1rpx solid var(--border);
  font-weight: 500;
}

.family-drop-item:last-child {
  border-bottom: none;
}

.family-drop-item.active {
  color: var(--gold);
  font-weight: 700;
  background: var(--gold-light);
}

.family-drop-item.add-item {
  color: var(--gold);
  font-weight: 600;
  justify-content: center;
  gap: 8rpx;
}

.check-mark {
  font-size: 28rpx;
  color: var(--gold);
}

/* 空引导卡片 */
.empty-guide {
  text-align: center;
  padding: 40rpx 32rpx;
}

/* 日历卡片 */
.calendar-card {
  padding: 32rpx;
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.cal-month {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.cal-nav {
  display: flex;
  gap: 16rpx;
}

.cal-nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: var(--theme-color);
  border: 2rpx solid var(--theme-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  transition: var(--transition);
}

.cal-nav-btn:active {
  background: #FAF7F2;
  opacity: 0.9;
}

/* 星期表头 */
.week-row {
  display: flex;
  margin-bottom: 12rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
}

/* 日历网格 */
.cal-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-day {
  width: 14.2857%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  cursor: pointer;
  background: #FAF8F5;
  margin: 3rpx 0;
}

.cal-day-num {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 1;
}

.cal-day.other-month {
  opacity: 0.25;
  background: transparent;
}

.cal-day.today {
  background: #FFFFFF;
  border: 2rpx solid var(--theme-color);
}

.cal-day.today .cal-day-num {
  color: var(--theme-color);
  font-weight: 800;
}

.cal-day.selected {
  background: var(--theme-color);
}

.cal-day.selected .cal-day-num {
  color: #FFFFFF;
  font-weight: 700;
}

.cal-day.selected.today {
  background: var(--theme-color);
  border-color: var(--theme-color);
}

.cal-day.selected.today .cal-day-num {
  color: #FFFFFF;
}

/* 已配餐指示点 */
.menu-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #000000;
  position: absolute;
  bottom: 6rpx;
}

.cal-day.selected .menu-dot {
  background: #FFFFFF;
}

/* 今日菜单卡片 */
.today-card {
  border-left: 6rpx solid var(--theme-color);
}

.today-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.today-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.edit-link {
  font-size: 26rpx;
  color: var(--theme-color);
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--theme-color);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.edit-link .iconfont {
  font-size: 20rpx;
}

/* 菜品药丸标签 */
.dish-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.dish-pill {
  background: #FCFAF2;
  color: var(--text-main);
  border: 1rpx solid var(--border);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.read-only-tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  background: #FDFDFB;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  gap: 8rpx;
}


/* 骨架屏组件样式 */
.skeleton-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skeleton-title-placeholder {
  width: 180rpx;
  height: 48rpx;
  margin-bottom: 0 !important;
}

.skeleton-badge-placeholder {
  width: 120rpx;
  height: 38rpx;
  border-radius: 20rpx;
  margin-bottom: 0 !important;
}

.skeleton-card {
  pointer-events: none;
}

.skeleton-month-placeholder {
  width: 160rpx;
  height: 40rpx;
  margin-bottom: 0 !important;
}

.skeleton-nav-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50% !important;
  margin-bottom: 0 !important;
}

.skeleton-day {
  width: 14.2857%;
  height: unset !important;
  aspect-ratio: 1 !important;
  border-radius: 16rpx !important;
  margin: 3rpx 0;
  margin-bottom: 0 !important;
}

.skeleton-today-title {
  width: 200rpx;
  height: 40rpx;
  margin-bottom: 0 !important;
}

.skeleton-edit-link {
  width: 80rpx;
  height: 44rpx;
  border-radius: 12rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-dish-pill {
  height: 56rpx;
  border-radius: 40rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-btn-placeholder {
  width: 100%;
  height: 84rpx;
  border-radius: var(--radius-sm) !important;
  margin-top: 32rpx;
  margin-bottom: 0 !important;
}

.skeleton-tip-placeholder {
  width: 60%;
  height: 24rpx;
  margin: 16rpx auto 0 auto !important;
  margin-bottom: 0 !important;
}

/* 优化首页空状态内边距 */
.index-page .empty-state {
  padding: 16rpx 0;
}

.empty-guide .btn-primary {
  margin-top: 16rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.clear-link {
  font-size: 26rpx;
  color: #E53935;
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: #FFFFFF;
  border: 1rpx solid #E53935;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.clear-link:active {
  background: rgba(229, 57, 53, 0.05);
}

/* 采购建议区域 (融合在菜单卡片底部) */
.shopping-section {
  margin-top: 36rpx;
  border-top: 2rpx dashed var(--border);
  padding-top: 32rpx;
}

.shopping-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.shopping-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.regenerate-link {
  font-size: 24rpx;
  color: var(--theme-color);
  font-weight: 600;
  display: flex;
  align-items: center;
  padding: 8rpx;
}

.regenerate-link:active {
  opacity: 0.7;
}

.shopping-content {
  background: #FAF8F5; /* 极轻奶油黄 */
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.shopping-text {
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.7;
  white-space: pre-wrap;
  display: block;
}

.shopping-notice {
  font-size: 22rpx;
  color: var(--text-muted);
  display: flex;
  align-items: flex-start;
  line-height: 1.5;
  padding: 8rpx 4rpx;
}

.shopping-notice.center {
  justify-content: center;
  margin-top: 16rpx;
}

.empty-shopping-section {
  padding: 16rpx 0 0 0;
  display: flex;
  flex-direction: column;
}

.btn-generate-shopping {
  width: 100% !important;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 84rpx;
  font-size: 26rpx !important;
  font-weight: 600 !important;
}

/* 采购建议预览区域折叠 */
.shopping-content-wrapper {
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
  border-radius: var(--radius-sm);
  pointer-events: none; /* 外部预览卡片静止显示，不滚动 */
}

.shopping-content.preview {
  max-height: 240rpx;
  overflow: hidden;
  margin-bottom: 0;
}

.view-details-btn-container {
  display: flex;
  justify-content: center;
  margin: 12rpx 0 24rpx 0;
}

.view-details-btn {
  width: auto !important;
  min-height: 0 !important;
  padding: 12rpx 36rpx !important;
  font-size: 24rpx !important;
  font-weight: 600 !important;
  border-radius: 30rpx !important;
  background: #FFFFFF !important;
  border: 1rpx solid var(--border) !important;
  color: var(--theme-color) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.2 !important;
  margin: 0 !important;
  box-shadow: none !important;
}

.view-details-btn:active {
  background: var(--gold-light) !important;
  opacity: 0.9;
}

/* Markdown 渲染样式 */
.md-container {
  padding: 12rpx 4rpx;
  color: var(--text-main);
  font-size: 26rpx;
  line-height: 1.8;
}

.md-h1 {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-top: 36rpx;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--border);
}

.md-h2 {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.md-h3 {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-color);
  margin-top: 24rpx;
  margin-bottom: 12rpx;
}

.md-p {
  font-size: 26rpx;
  margin-bottom: 16rpx;
  color: var(--text-main);
}

.md-bullet {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
}

.md-bullet-dot {
  font-size: 32rpx;
  color: var(--theme-color);
  margin-right: 12rpx;
  line-height: 1;
  margin-top: -4rpx;
}

.md-bullet-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-main);
}

.md-table {
  width: 100%;
  border-collapse: collapse;
  margin: 20rpx 0 32rpx 0;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1rpx solid var(--border);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.01);
}

.md-thead {
  background: var(--gold-light);
}

.md-tr {
  display: flex;
  border-bottom: 1rpx solid var(--border);
}

.md-tr:last-child {
  border-bottom: none;
}

.md-th, .md-td {
  flex: 1;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: var(--text-main);
  text-align: left;
  word-break: break-all;
}

.md-th {
  font-weight: 700;
  color: var(--text-main);
}

.md-td {
  background: #FFFFFF;
}

.md-tbody .md-tr:nth-child(even) .md-td {
  background: #FAF9F6;
}

.shopping-details-sheet {
  max-height: 85% !important;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom)) !important;
}

.shopping-details-scroll {
  height: 65vh; /* 显式设置高度，确保微信原生 scroll-view 能正确计算滚动视口并开启滚动 */
  padding: 0 4rpx;
}

/* ============================================================
   海报生成相关样式
   ============================================================ */
.family-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-action-btn {
  display: flex;
  align-items: center;
  background: var(--gold-light);
  color: var(--gold);
  border: 1rpx solid rgba(212, 178, 140, 0.15);
  border-radius: 30rpx;
  padding: 0 20rpx;
  height: 52rpx;
  line-height: 50rpx;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.header-action-btn:active {
  opacity: 0.7;
}

/* 日历选择面板 */
.poster-calendar-box {
  background: #FFF;
  border-radius: var(--radius);
  padding: 16rpx;
  box-sizing: border-box;
}

/* 海报预览样式 */
.poster-preview-scroll {
  width: 100%;
  height: 60vh;
  background: #FDFDFB;
  border-radius: var(--radius);
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.poster-preview-content {
  padding: 40rpx 32rpx;
  background: #FFFFFF;
  color: #222222;
}

.poster-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.poster-title-main {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.poster-subtitle {
  font-size: 20rpx;
  color: var(--gold);
  font-weight: 600;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.poster-divider {
  width: 60rpx;
  height: 4rpx;
  background: var(--gold);
  margin: 20rpx auto 0 auto;
}

.poster-date-section {
  margin-bottom: 32rpx;
}

.poster-date-header {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 20rpx;
  border-left: 8rpx solid var(--gold);
  padding-left: 16rpx;
  height: 36rpx;
  line-height: 36rpx;
}

.poster-dishes-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-left: 12rpx;
}

.poster-dish-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.poster-dish-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.poster-dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.poster-dish-category {
  font-size: 18rpx;
  background: var(--gold-light);
  color: var(--gold);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-weight: 600;
}

.poster-dish-detail {
  font-size: 22rpx;
  line-height: 1.5;
  display: flex;
  align-items: flex-start;
  padding-left: 8rpx;
}

.poster-detail-label {
  color: var(--text-muted);
  flex-shrink: 0;
  font-weight: 600;
}

.poster-detail-val {
  color: var(--text-main);
}

.poster-empty-state {
  font-size: 24rpx;
  color: var(--text-light);
  font-style: italic;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 8rpx;
  text-align: center;
}

.poster-section-divider {
  margin-top: 32rpx;
  height: 1rpx;
  background: var(--border);
  border: none;
}

.poster-footer {
  margin-top: 50rpx;
  text-align: center;
}

.poster-footer-tip {
  font-size: 18rpx;
  color: var(--text-light);
}

.floating-poster-btn {
  position: fixed;
  right: 24rpx;
  bottom: 140rpx;
  width: 180rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: linear-gradient(135deg, #E6C594, #D4B28C);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(212, 178, 140, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  
  /* Collapsed default state: offset by 166rpx, leaving 38rpx visible */
  opacity: 0.65;
  transform: translateX(166rpx) scale(0.9);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.floating-poster-btn.expanded {
  opacity: 1;
  transform: translateX(0) scale(1);
  box-shadow: 0 8rpx 24rpx rgba(212, 178, 140, 0.45);
}

.floating-poster-btn:active {
  opacity: 0.9;
}

