<!-- miniprogram/pages/dishes/index.wxml -->
<wxs module="iconMap">
  var getTabIcon = function(tab) {
    if (tab === '全部') return 'iconfont-menu';
    if (tab === '热菜') return 'iconfont-hot-dishes';
    if (tab === '凉菜') return 'iconfont-cold-dishes';
    if (tab === '汤品') return 'iconfont-soup';
    if (tab === '主食') return 'iconfont-rice';
    return 'iconfont-other';
  };
  module.exports = {
    getTabIcon: getTabIcon
  };
</wxs>
<view class="page-container dishes-page">

  <!-- 骨架屏加载状态 -->
  <block wx:if="{{ loading }}">
    <!-- 顶部栏骨架 -->
    <view class="dishes-header skeleton-dishes-header">
      <view class="shimmer-line skeleton-title-placeholder"></view>
      <view class="skeleton-header-actions" wx:if="{{ memberRole !== 'read' }}">
        <view class="shimmer-line skeleton-icon-btn"></view>
        <view class="shimmer-line skeleton-icon-btn"></view>
      </view>
    </view>

    <!-- 搜索栏骨架 -->
    <view class="search-bar skeleton-search-bar">
      <view class="shimmer-line skeleton-search-input"></view>
    </view>

    <!-- 分类 Tab 骨架 -->
    <view class="tab-scroll skeleton-tab-scroll">
      <view class="shimmer-line skeleton-tab-pill" wx:for="{{ 5 }}" wx:key="index"></view>
    </view>

    <!-- 菜品列表骨架 -->
    <view class="dish-list-scroll">
      <view class="dish-list">
        <view class="card dish-card skeleton-dish-card" wx:for="{{ 6 }}" wx:key="index">
          <view class="dish-info skeleton-dish-info">
            <view class="shimmer-line skeleton-dish-cat"></view>
            <view class="shimmer-line skeleton-dish-name"></view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <!-- 顶部操作栏 -->
    <view class="dishes-header">
      <text class="dishes-title">菜品库 ({{ dishes.length }})</text>
      <view class="header-actions" wx:if="{{ memberRole !== 'read' }}">
        <view class="icon-btn" style="background: var(--border); color: var(--text-main); border-color: var(--border);" bindtap="onToggleBatchMode" wx:if="{{ filteredDishes.length > 0 || isBatchMode }}">
          <text class="iconfont {{ isBatchMode ? 'iconfont-wrong' : 'iconfont-option' }}"></text>
          <text>{{ isBatchMode ? '取消' : '批量管理' }}</text>
        </view>
        <view class="icon-btn ai-btn" bindtap="onOpenAiImport" wx:if="{{ !isBatchMode }}"><text class="iconfont iconfont-ai"></text><text>AI导入</text></view>
        <view class="icon-btn add-btn" bindtap="onOpenAddModal" wx:if="{{ !isBatchMode }}"><text class="iconfont iconfont-add"></text><text>新增</text></view>
      </view>
    </view>

    <!-- 只读提示 -->
    <view class="read-only-banner" wx:if="{{ memberRole === 'read' }}">
      <text class="iconfont iconfont-lock"></text>
      <text>只读模式：您可浏览菜品库，无法添加或删除</text>
    </view>

    <!-- 搜索栏 -->
    <view class="search-bar">
      <input
        class="input-field search-input"
        placeholder="搜索菜品..."
        value="{{ searchQuery }}"
        bindinput="onSearchInput"
      />
    </view>

    <!-- 分类 Tab -->
    <scroll-view class="tab-scroll" scroll-x="true">
      <view
        class="tab-pill {{ activeTab === item ? 'active' : '' }}"
        wx:for="{{ tabs }}"
        wx:key="index"
        bindtap="onTabChange"
        data-tab="{{ item }}"
      >
        {{ item }}
      </view>
    </scroll-view>

    <!-- 菜品列表 -->
    <scroll-view class="dish-list-scroll animate-in" scroll-y="true" wx:if="{{ filteredDishes.length > 0 }}">
      <view class="dish-list">
        <view class="dish-card {{ item.remark === 'AI导入' ? 'is-ai-imported' : '' }}" wx:for="{{ filteredDishes }}" wx:key="_id" bindtap="{{ isBatchMode ? 'onToggleSelectDish' : 'onOpenEditModal' }}" data-dish="{{ item }}" data-id="{{ item._id }}">
          <view style="display: flex; align-items: center; gap: 20rpx; flex: 1; min-width: 0;">
            <view class="dish-select-box" wx:if="{{ isBatchMode }}">
              <checkbox class="dish-checkbox" checked="{{ selectedDishIds[item._id] }}" />
            </view>
            <text class="iconfont iconfont-ai ai-star-badge" wx:if="{{ item.remark === 'AI导入' && !isBatchMode }}"></text>
            <view class="dish-info" style="flex: 1; min-width: 0;">
              <view class="dish-name-row">
                <text class="dish-card-cat">{{ item.category }}</text>
                <text class="dish-card-name">{{ item.name }}</text>
              </view>
              <text class="dish-card-remark" wx:if="{{ item.remark && item.remark !== 'AI导入' }}">{{ item.remark }}</text>
            </view>
          </view>
          <view
            class="trash-btn"
            catchtap="onDeleteDish"
            data-id="{{ item._id }}"
            data-name="{{ item.name }}"
            wx:if="{{ memberRole !== 'read' && !isBatchMode }}"
          >
            <text class="iconfont iconfont-delete"></text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 空状态 -->
    <view class="card empty-state animate-in" wx:if="{{ filteredDishes.length === 0 && !loading }}">
      <view class="empty-icon iconfont {{ iconMap.getTabIcon(activeTab) }}" style="font-size: 80rpx;"></view>
      <view class="empty-text">菜品库空空如也
  点击右上角新增或 AI 导入吧</view>
    </view>

    <!-- 新增菜品 Modal -->
    <view class="modal-mask" wx:if="{{ showAddModal }}" bindtap="onCloseAddModal">
      <view class="modal-sheet" catchtap="noop">
        <view class="modal-header">
          <text class="modal-title">新增菜品</text>
          <view class="modal-close" bindtap="onCloseAddModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">菜品名称</text>
          <input
            class="input-field"
            placeholder="请输入菜品名称，如「辣椒炒肉」"
            value="{{ newDishName }}"
            bindinput="onNewDishNameInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">菜品类别</text>
          <view class="custom-select-container open-up">
            <view class="form-picker {{ showCategoryPicker ? 'active' : '' }}" bindtap="onToggleCategoryPicker">
              <text>{{ newDishCategory }}</text>
              <text class="iconfont iconfont-down-line select-arrow {{ showCategoryPicker ? 'open' : '' }}"></text>
            </view>
            <view class="custom-select-options {{ showCategoryPicker ? 'show' : '' }}">
              <view
                class="custom-select-option {{ categoryIndex === index ? 'selected' : '' }}"
                wx:for="{{ categories }}"
                wx:key="index"
                bindtap="onSelectCategory"
                data-index="{{ index }}"
              >
                <text>{{ item }}</text>
              </view>
            </view>
            <view class="custom-select-backdrop" wx:if="{{ showCategoryPicker }}" bindtap="onCloseCategoryPicker"></view>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">备注 / 描述（可选）</text>
          <input
            class="input-field"
            placeholder="如「不放辣/宝贝爱吃」"
            value="{{ newDishRemark }}"
            bindinput="onNewDishRemarkInput"
          />
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onAddDish"
          style="margin-top: 16rpx;"
        >
          确认保存
        </button>
      </view>
    </view>

    <!-- AI 批量导入 Modal -->
    <view class="modal-mask" wx:if="{{ showAiImportModal }}" bindtap="onCloseAiImport">
      <view class="modal-sheet" catchtap="noop">
        <view class="modal-header">
          <view class="modal-title">
            <text class="iconfont iconfont-ai"></text>
            <text>AI 批量解析导入</text>
          </view>
          <view class="modal-close" bindtap="onCloseAiImport">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <textarea
          class="ai-textarea"
          placeholder="输入或粘贴想要导入的菜品文本。例如：「帮我加一下红烧排骨、清茑鲈鱼，还有一道紫菜蛋汤」"
          value="{{ bulkImportText }}"
          bindinput="onBulkImportInput"
          style="margin-bottom: 24rpx;"
        />

        <view class="ai-tip">
          <text class="iconfont iconfont-info"></text>
          <text>AI 会自动提取菜名并按类别（热菜/汤品/凉菜）分类，去重后存入菜品库。</text>
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onCommitAiImport"
          disabled="{{ importLoading }}"
          style="margin-top: 24rpx;"
        >
          <text class="iconfont iconfont-ai"></text>
          <text>{{ importLoading ? 'AI 分析导入中...' : '开始 AI 解析并导入' }}</text>
        </button>
      </view>
    </view>
    <!-- 编辑菜品 Modal -->
    <view class="modal-mask" wx:if="{{ showEditModal }}" bindtap="onCloseEditModal">
      <view class="modal-sheet" catchtap="noop">
        <view class="modal-header">
          <text class="modal-title">编辑菜品</text>
          <view class="modal-close" bindtap="onCloseEditModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">菜品名称</text>
          <input
            class="input-field"
            placeholder="请输入菜品名称，如「辣椒炒肉」"
            value="{{ editDishName }}"
            bindinput="onEditDishNameInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">菜品类别</text>
          <view class="custom-select-container open-up">
            <view class="form-picker {{ showEditCategoryPicker ? 'active' : '' }}" bindtap="onToggleEditCategoryPicker">
              <text>{{ editDishCategory }}</text>
              <text class="iconfont iconfont-down-line select-arrow {{ showEditCategoryPicker ? 'open' : '' }}"></text>
            </view>
            <view class="custom-select-options {{ showEditCategoryPicker ? 'show' : '' }}">
              <view
                class="custom-select-option {{ editCategoryIndex === index ? 'selected' : '' }}"
                wx:for="{{ categories }}"
                wx:key="index"
                bindtap="onSelectEditCategory"
                data-index="{{ index }}"
              >
                <text>{{ item }}</text>
              </view>
            </view>
            <view class="custom-select-backdrop" wx:if="{{ showEditCategoryPicker }}" bindtap="onCloseEditCategoryPicker"></view>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">备注 / 描述（可选）</text>
          <input
            class="input-field"
            placeholder="如「不放辣/宝贝爱吃」"
            value="{{ editDishRemark }}"
            bindinput="onEditDishRemarkInput"
          />
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onUpdateDish"
          style="margin-top: 16rpx;"
        >
          确认保存
        </button>
      </view>
    </view>
    <!-- 批量操作底部栏 -->
    <view class="batch-bottom-bar" wx:if="{{ isBatchMode }}">
      <view class="batch-select-all" bindtap="onToggleSelectAll">
        <checkbox class="batch-checkbox" checked="{{ isAllSelected }}" disabled="{{ filteredDishes.length === 0 }}" />
        <text>全选</text>
      </view>
      <view class="batch-actions-right">
        <text class="batch-count">已选 {{ selectedCount }} 项</text>
        <button class="batch-delete-btn {{ selectedCount > 0 ? 'active' : '' }}" disabled="{{ selectedCount === 0 }}" bindtap="onBatchDelete">删除</button>
      </view>
    </view>

    <!-- 自定义 Toast & Loading -->
    <view class="custom-toast-backdrop" wx:if="{{ toastData.show && toastData.type === 'loading' }}" catchtap="noop" catchtouchmove="noop"></view>
    <view class="custom-toast {{ toastData.show ? 'show' : '' }}">
      <view class="custom-toast-content">
        <view class="custom-toast-loading-spinner" wx:if="{{ toastData.type === 'loading' }}"></view>
        <text class="iconfont iconfont-success custom-toast-icon success" wx:elif="{{ toastData.type === 'success' }}"></text>
        <text class="iconfont iconfont-info custom-toast-icon info" wx:elif="{{ toastData.type === 'info' }}"></text>
        <text class="custom-toast-title" wx:if="{{ toastData.title }}">{{ toastData.title }}</text>
      </view>
    </view>
  </block>

  <!-- 删除菜品确认 Modal -->
  <view class="modal-mask" wx:if="{{ showDeleteDishConfirm }}" bindtap="onCloseDeleteDishConfirm">
    <view class="modal-sheet" catchtap="noop" style="padding-bottom: 60rpx; text-align: center;">
      <view class="modal-header" style="border: none; padding-bottom: 0;">
        <view style="flex: 1;"></view>
        <view class="modal-close" bindtap="onCloseDeleteDishConfirm">
          <text class="iconfont iconfont-wrong"></text>
        </view>
      </view>
      <view style="margin-bottom: 24rpx; display: inline-block;">
        <text class="iconfont iconfont-info" style="font-size: 80rpx; color: #E53935;"></text>
      </view>
      <view style="font-size: 32rpx; font-weight: 700; color: var(--text-main); margin-bottom: 16rpx;">确认删除</view>
      <view style="font-size: 26rpx; color: var(--text-muted); line-height: 1.6; padding: 0 32rpx; margin-bottom: 40rpx;">确定要删除「{{ deleteDishName }}」吗？</view>
      <view style="display: flex; gap: 20rpx; padding: 0 32rpx;">
        <button class="btn-secondary" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;" bindtap="onCloseDeleteDishConfirm">取消</button>
        <button class="btn-primary" style="flex: 1; background: #E53935; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; box-shadow: none;" bindtap="onCommitDeleteDish">确认删除</button>
      </view>
    </view>
  </view>

  <!-- 批量删除确认 Modal -->
  <view class="custom-dialog-mask" wx:if="{{ showBatchDeleteConfirm }}" bindtap="onCloseBatchDeleteConfirm">
    <view class="custom-dialog-box" catchtap="noop">
      <view class="custom-dialog-icon-wrap" style="background: rgba(229, 57, 53, 0.08);">
        <text class="iconfont iconfont-info" style="font-size: 64rpx; color: #E53935;"></text>
      </view>
      <view class="custom-dialog-title">确认删除</view>
      <view class="custom-dialog-content">确定要删除已选的 {{ selectedCount }} 道菜吗？删除后将不可恢复！</view>
      <view class="custom-dialog-footer">
        <button class="custom-dialog-btn-cancel" bindtap="onCloseBatchDeleteConfirm">取消</button>
        <button class="custom-dialog-btn-confirm" style="background: #E53935 !important; box-shadow: none !important;" bindtap="onCommitBatchDelete">确认删除</button>
      </view>
    </view>
  </view>

</view>
