/* miniprogram/pages/dishes/index.wxss */

.dishes-page {
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding-top: 24rpx;
  padding-bottom: 32rpx !important;
  box-sizing: border-box;
}

.dishes-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

.dishes-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.header-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.icon-btn {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid var(--theme-color);
  transition: var(--transition);
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.ai-btn {
  background: #FFFFFF;
  color: var(--theme-color);
}

.ai-btn:active {
  background: #FAF7F2;
  opacity: 0.9;
}

.add-btn {
  background: var(--theme-color);
  color: #FFFFFF;
  border-color: var(--theme-color);
}

.add-btn:active {
  opacity: 0.9;
  filter: brightness(0.95);
}

.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  height: 80rpx;
  font-size: 26rpx;
  border-radius: 40rpx;
  padding: 0 32rpx;
}

.tab-scroll {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.tab-pill {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-muted);
  background: #FFFFFF;
  border: 1rpx solid var(--border);
  margin-right: 12rpx;
  white-space: nowrap;
}

.tab-pill.active {
  background: var(--text-main);
  color: #FFFFFF;
  border-color: var(--text-main);
}

.dish-list-scroll {
  flex: 1;
  min-height: 0;
  margin-bottom: 16rpx;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-top: 20rpx;
  padding-bottom: 24rpx;
}

.dishes-page .empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

.dish-card {
  position: relative;
  background: var(--card-bg);
  border-radius: var(--radius-sm);
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid var(--border);
}

.ai-star-badge {
  position: absolute;
  top: -14rpx;
  left: 6rpx;
  font-size: 28rpx;
  color: var(--gold);
  z-index: 5;
  line-height: 1;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dish-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.dish-card-cat {
  font-size: 22rpx;
  color: var(--text-muted);
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.dish-card-remark {
  font-size: 22rpx;
  color: var(--text-muted);
  font-style: italic;
}

.trash-btn {
  font-size: 36rpx;
  padding: 8rpx;
  color: #E53935;
  opacity: 0.9;
}

.ai-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background: #FDFDFB;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.6;
}

.ai-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  background: var(--gold-light);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  line-height: 1.6;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.ai-tip .iconfont {
  margin-top: 6rpx;
}

/* 骨架屏组件样式 */
.skeleton-dishes-header {
  pointer-events: none;
}

.skeleton-title-placeholder {
  width: 180rpx;
  height: 48rpx;
  margin-bottom: 0 !important;
}

.skeleton-header-actions {
  display: flex;
  gap: 16rpx;
}

.skeleton-icon-btn {
  width: 120rpx;
  height: 52rpx;
  border-radius: 12rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-search-bar {
  pointer-events: none;
}

.skeleton-search-input {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-sm) !important;
  margin-bottom: 0 !important;
}

.skeleton-tab-scroll {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  pointer-events: none;
}

.skeleton-tab-pill {
  width: 100rpx;
  height: 56rpx;
  border-radius: 40rpx !important;
  flex-shrink: 0;
  margin-bottom: 0 !important;
}

.skeleton-dish-card {
  pointer-events: none;
}

.skeleton-dish-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.skeleton-dish-cat {
  width: 80rpx;
  height: 32rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-dish-name {
  width: 220rpx;
  height: 36rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

