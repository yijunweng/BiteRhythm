/* miniprogram/pages/dishes/index.wxss */

.dishes-container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 顶部操作区 */
.action-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-section {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.header-buttons {
  display: flex;
  gap: 16rpx;
}

.mini-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

/* 搜索框 */
.search-wrapper {
  margin-bottom: 24rpx;
}

/* 选项卡栏 */
.tab-scroll {
  white-space: nowrap;
  margin-bottom: 30rpx;
  padding-bottom: 10rpx;
}

.tab-pill {
  display: inline-block;
  padding: 14rpx 32rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 20rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--text-sub);
  transition: all 0.2s ease;
}

.tab-pill.active {
  background: var(--primary-light);
  color: var(--primary-color);
  border-color: rgba(108,142,191,0.3);
  font-weight: 700;
}

/* 菜品展示列表 */
.dishes-list-wrapper {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dish-repo-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  box-shadow: 0 8rpx 24rpx var(--shadow-color);
  border-radius: 24rpx;
  padding: 30rpx;
  animation: fadeIn 0.3s ease;
}

.dish-repo-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.dish-repo-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dish-repo-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.dish-repo-remark {
  font-size: 24rpx;
  color: var(--text-sub);
  font-style: italic;
}

.btn-delete-trash {
  font-size: 32rpx;
  color: var(--accent-color);
  opacity: 0.6;
  padding: 10rpx;
}

.btn-delete-trash:active {
  opacity: 1;
}

/* AI 批量解析面板样式 */
.ai-textarea {
  width: 100%;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(155, 184, 167, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

.ai-textarea:focus {
  background: #FFFFFF;
  border-color: var(--green-color);
}

.ai-tips {
  font-size: 22rpx;
  color: var(--text-sub);
  margin-bottom: 30rpx;
}

/* 表单输入组 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-sub);
  margin-bottom: 12rpx;
  display: block;
}

.form-picker {
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(108, 142, 191, 0.15);
  border-radius: 20rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  font-size: 28rpx;
}

/* 浮窗 Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(51, 60, 72, 0.4);
  backdrop-filter: blur(10px);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  background: #F6F8FC;
  width: 100%;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
}

.modal-close {
  font-size: 44rpx;
  color: var(--text-light);
  padding: 0 10rpx;
}
