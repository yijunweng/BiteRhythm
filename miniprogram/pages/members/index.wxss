/* miniprogram/pages/members/index.wxss */

.members-container {
  padding: 30rpx;
  min-height: 100vh;
}

.family-title-card {
  text-align: center;
  margin-bottom: 30rpx;
}

.family-label {
  font-size: 24rpx;
  color: var(--text-sub);
}

.family-name-text {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-top: 10rpx;
}

/* 列表包装器 */
.list-section-card {
  margin-bottom: 30rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.member-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.4);
  border: 1rpx solid rgba(108,142,191,0.08);
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
}

.member-info-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--primary-color);
  font-weight: bold;
}

.member-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.role-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  width: fit-content;
}

.role-tag.admin {
  background: var(--primary-light);
  color: var(--primary-color);
}

.role-tag.write {
  background: var(--accent-light);
  color: var(--accent-color);
}

.role-tag.read {
  background: var(--green-light);
  color: var(--green-color);
}

.member-action-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-dot-btn {
  font-size: 32rpx;
  color: var(--text-light);
  padding: 10rpx 20rpx;
}

/* 待审批列表卡片 */
.pending-card {
  border: 1rpx dashed var(--accent-color);
}

.pending-actions {
  display: flex;
  gap: 10rpx;
}

.approve-btn-small {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
  background: var(--primary-color);
  color: #FFFFFF;
}

.approve-btn-small.green {
  background: var(--green-color);
}

.reject-btn-small {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
  background: var(--accent-light);
  color: var(--accent-color);
  border: 1rpx solid rgba(226, 155, 155, 0.2);
}

/* 申请加入的流程页面样式 */
.join-flow-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 60rpx 40rpx;
  margin-top: 100rpx;
}

.join-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.join-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.join-inviter {
  font-size: 26rpx;
  color: var(--text-sub);
  margin-top: 12rpx;
  margin-bottom: 50rpx;
}
