/* miniprogram/pages/members/index.wxss */

.members-page {
  padding-top: 60rpx;
}

/* 品牌头 */
.brand-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.brand-logo {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.brand-sub {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 邀请栏 */
.invite-banner {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 0 8rpx;
}

.invite-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
  margin-bottom: 16rpx;
}

.invite-desc {
  font-size: 28rpx;
  color: var(--text-muted);
  line-height: 1.7;
  display: block;
}

/* 输入提示 */
.nickname-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
  display: block;
  margin-bottom: 4rpx;
}

/* 成功状态 */
.success-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  text-align: center;
}

.success-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
  display: block;
}

.success-desc {
  font-size: 28rpx;
  color: var(--text-muted);
  line-height: 1.7;
  display: block;
}
