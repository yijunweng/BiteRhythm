/* miniprogram/pages/admin-settings/index.wxss */

.settings-page {
  padding-top: 24rpx;
}

/* 锁屏界面 */
.lock-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 40rpx;
  text-align: center;
}

.lock-icon-wrap {
  margin-bottom: 32rpx;
  opacity: 0.85;
}

.lock-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
  display: block;
}

.lock-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 40rpx;
  display: block;
}

.openid-card {
  width: 100%;
  text-align: left;
}

.openid-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
  margin-bottom: 16rpx;
}

.openid-value-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.openid-text {
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: monospace;
  flex: 1;
  word-break: break-all;
}

.copy-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--theme-color);
  white-space: nowrap;
  padding: 6rpx 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--theme-color);
  border-radius: 8rpx;
}

.openid-tip {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.openid-tip .iconfont {
  margin-top: 6rpx;
}

/* 超管信息卡 */
.admin-info-card {
  border-left: 6rpx solid var(--gold);
}

.admin-badge {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 12rpx;
}

.admin-openid {
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: monospace;
  display: block;
  margin-bottom: 12rpx;
}

.admin-tip {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

/* 菜单列表 */
.settings-menu-item {
  background: var(--card-bg);
  padding: 28rpx 32rpx;
  border-radius: var(--radius-sm);
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.settings-menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.settings-menu-icon {
  font-size: 36rpx;
}

.settings-menu-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
  margin-bottom: 4rpx;
}

.settings-menu-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
}

.chevron {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 子页返回按钮 */
.subpage-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

/* 家庭信息行 */
.family-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.family-info-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

/* 待审批 */
.pending-card {
  border-left: 6rpx solid #FFC107;
}

.pending-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.badge-pending {
  background: #FFF9C4;
  color: #F57F17;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 成员列表 */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FAFAFA;
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
}

.member-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--gold-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-avatar-letter {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--gold);
}

.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.member-sub {
  font-size: 22rpx;
  color: var(--text-muted);
}

.role-tags {
  display: flex;
  gap: 8rpx;
}

.role-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.role-tag.admin {
  background: var(--gold-light);
  color: var(--gold);
}

.role-tag.write {
  background: #E3F2FD;
  color: #1E88E5;
}

.role-tag.read {
  background: #FFEBEE;
  color: #E53935;
}

.approve-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.approve-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: #FFFFFF;
  color: var(--theme-color);
  border: 1rpx solid var(--theme-color);
}

.approve-btn.blue {
  background: var(--theme-color);
  color: #FFFFFF;
  border: none;
}

.reject-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: transparent;
  color: #E53935;
  border: none;
}

.member-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: #FFFFFF;
  color: var(--theme-color);
  border: 1rpx solid var(--theme-color);
}

.action-btn.danger {
  background: transparent;
  color: #E53935;
  border: none;
}

/* 大模型配置子页 */
.llm-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

/* 骨架屏组件样式 */
.skeleton-settings-section-title {
  width: 160rpx;
  height: 40rpx;
  border-radius: 8rpx !important;
  margin-bottom: 24rpx !important;
}

.skeleton-family-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.skeleton-family-name {
  width: 280rpx;
  height: 36rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-badge {
  width: 80rpx;
  height: 36rpx;
  border-radius: 20rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-member-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-member-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FAFAFA;
  border-radius: var(--radius-sm);
  padding: 20rpx 24rpx;
  pointer-events: none;
}

.skeleton-member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50% !important;
  flex-shrink: 0;
  margin-bottom: 0 !important;
}

.skeleton-member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.skeleton-member-name {
  width: 160rpx;
  height: 32rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

.skeleton-member-role-tag {
  width: 120rpx;
  height: 28rpx;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
}

