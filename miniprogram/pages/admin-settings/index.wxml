<!-- miniprogram/pages/admin-settings/index.wxml -->
<view class="page-container settings-page">

  <!-- ======= 非超管锁屏界面 ======= -->
  <view wx:if="{{ !isSystemAdmin }}">
    <view class="lock-screen animate-in">
      <!-- Shield SVG 图标 -->
      <view class="lock-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#D4B28C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
      </view>
      <text class="lock-title">系统配置已锁定保护</text>
      <text class="lock-desc">为保障家庭数据隐私与大模型密鑰安全，此设置页面仅超级管理员（雇主）可访问查看。</text>

      <!-- 展示当前 OpenID -->
      <view class="card openid-card">
        <text class="openid-label">您的微信 OpenID</text>
        <view class="openid-value-row">
          <text class="openid-text" selectable>{{ myOpenid || '获取中...' }}</text>
          <view class="copy-btn" bindtap="onCopyOpenid" wx:if="{{ myOpenid }}">复制</view>
        </view>
        <view class="openid-tip">
          <text class="iconfont iconfont-info"></text>
          <text>如果您是超级管理员（雇主/主开发者），请复制此 OpenID 并将其配置到项目文件 miniprogram/config.js 中的 superAdminOpenId 字段，重新编译即可。</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ======= 超管界面 ======= -->
  <block wx:else>

    <!-- 主菜单页 -->
    <view wx:if="{{ subpage === 'home' }}" class="animate-in">
      <!-- 项目信息卡 -->
      <view class="card admin-info-card">
        <view class="admin-badge">超级管理员权限已启用</view>
        <text class="admin-openid" selectable>{{ myOpenid }}</text>
        <text class="admin-tip">您的 OpenID 已成功匹配超管凭证。以下配置保存在微信云端数据库，对任何家庭成员及做饥阿姨不公开。</text>
      </view>

      <!-- 菜单列表 -->
      <view class="settings-menu-item" bindtap="onGoSubpage" data-page="members">
        <view class="settings-menu-left">
          <text class="settings-menu-icon iconfont iconfont-family"></text>
          <view>
            <text class="settings-menu-title">成员与协作管理</text>
            <text class="settings-menu-desc">审批新成员、调整权限、生成邀请链接</text>
          </view>
        </view>
        <text class="iconfont iconfont-right-line chevron"></text>
      </view>

      <view class="settings-menu-item" bindtap="onGoSubpage" data-page="llm">
        <view class="settings-menu-left">
          <text class="settings-menu-icon iconfont iconfont-ai"></text>
          <view>
            <text class="settings-menu-title">大模型参数配置</text>
            <text class="settings-menu-desc">设置 API 提供商、密鑰与模型名称</text>
          </view>
        </view>
        <text class="iconfont iconfont-right-line chevron"></text>
      </view>
    </view>

    <!-- 子页 1：成员管理 -->
    <view wx:if="{{ subpage === 'members' }}" class="animate-in">
      <view class="subpage-back" bindtap="onBackToHome">
        <text class="iconfont iconfont-left-line"></text>
        <text>返回设置菜单</text>
      </view>

      <!-- 骨架屏加载状态 -->
      <block wx:if="{{ membersLoading }}">
        <!-- 当前家庭骨架 -->
        <view class="card skeleton-card">
          <view class="shimmer-line skeleton-settings-section-title"></view>
          <view class="family-info-row skeleton-family-info-row">
            <view class="shimmer-line skeleton-family-name"></view>
            <view class="shimmer-line skeleton-badge"></view>
          </view>
          <view class="shimmer-line skeleton-btn-placeholder" style="margin-top: 28rpx; height: 84rpx;"></view>
        </view>

        <!-- 成员列表骨架 -->
        <view class="card skeleton-card">
          <view class="shimmer-line skeleton-settings-section-title" style="width: 220rpx;"></view>
          <view class="member-list skeleton-member-list">
            <view class="member-item skeleton-member-item" wx:for="{{ 3 }}" wx:key="index">
              <view class="shimmer-line skeleton-member-avatar"></view>
              <view class="member-info skeleton-member-info">
                <view class="shimmer-line skeleton-member-name"></view>
                <view class="shimmer-line skeleton-member-role-tag"></view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <block wx:else>
        <!-- 当前家庭 -->
        <view class="card">
          <view class="section-title">当前家庭</view>
          <view class="family-info-row">
            <view style="display: flex; align-items: center; gap: 16rpx;">
              <text class="family-info-name">{{ currentFamilyName || '未加入任何家庭' }}</text>
              <view class="badge badge-gold" wx:if="{{ currentFamilyId }}">{{ approvedMembers.length }}人</view>
            </view>
            <view class="family-action-icons" wx:if="{{ currentFamilyId }}">
              <text class="iconfont iconfont-modify" bindtap="onOpenRenameFamilyModal"></text>
            </view>
          </view>

          <!-- 邀请按钮 -->
          <button
            class="btn-primary btn-invite"
            hover-class="btn-primary-hover"
            open-type="share"
            wx:if="{{ currentFamilyId }}"
          >
            <text class="iconfont iconfont-wechat" style="font-size: 36rpx;"></text>
            <text>微信邀请新成员</text>
          </button>
        </view>

        <!-- 待审批列表 -->
        <view class="card pending-card" wx:if="{{ pendingMembers.length > 0 }}">
          <view class="pending-header">
            <text class="section-title" style="color: #F57F17; margin-bottom: 0;">待审批申请</text>
            <view class="badge badge-pending">{{ pendingMembers.length }}个申请</view>
          </view>

          <view class="member-list">
            <view class="member-item" wx:for="{{ pendingMembers }}" wx:key="_id">
              <view class="member-avatar-wrap">
                <text class="member-avatar-letter">{{ item.nickname ? item.nickname[0] : '?' }}</text>
              </view>
              <view class="member-info">
                <text class="member-name">{{ item.nickname }}</text>
                <text class="member-sub">申请加入</text>
              </view>
              <view class="approve-actions">
                <view class="approve-btn blue" bindtap="onApprove" data-id="{{ item._id }}" data-role="write">设为家人</view>
                <view class="approve-btn" bindtap="onApprove" data-id="{{ item._id }}" data-role="read">设为阿姨</view>
                <view class="reject-btn" bindtap="onReject" data-id="{{ item._id }}">拒绝</view>
              </view>
            </view>
          </view>
        </view>

        <!-- 已加入成员 -->
        <view class="card">
          <text class="section-title">家庭成员 ({{ approvedMembers.length }})</text>
          <view class="member-list">
            <view class="member-item" wx:for="{{ approvedMembers }}" wx:key="_id">
              <view class="member-avatar-wrap">
                <text class="member-avatar-letter">{{ item.nickname ? item.nickname[0] : '?' }}</text>
              </view>
              <view class="member-info">
                <text class="member-name">{{ item.nickname }}</text>
                <view class="role-tags">
                  <text class="role-tag admin" wx:if="{{ item.role === 'admin' }}">管理员</text>
                  <text class="role-tag write" wx:if="{{ item.role === 'write' }}">家人 (可读写)</text>
                  <text class="role-tag read" wx:if="{{ item.role === 'read' }}">阿姨 (只读)</text>
                </view>
              </view>
              <!-- 管理员操作按钮 -->
              <view class="member-actions">
                <view class="action-btn" bindtap="onEditMember" data-id="{{ item._id }}" data-nickname="{{ item.nickname }}" data-role="{{ item.role }}">改名</view>
                <view class="action-btn danger" bindtap="onRemoveMember" data-id="{{ item._id }}" data-name="{{ item.nickname }}" wx:if="{{ item.role !== 'admin' }}">移除</view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- 子页 2：大模型配置 -->
    <view wx:if="{{ subpage === 'llm' }}" class="animate-in">
      <view class="subpage-back" bindtap="onBackToHome">
        <text class="iconfont iconfont-left-line"></text>
        <text>返回设置菜单</text>
      </view>

      <view class="card">
        <text class="section-title">大模型参数配置</text>
        <text class="llm-desc">配置安全保存于微信云开发数据库，对家庭成员完全屏蔽。</text>

        <view class="form-group" style="margin-top: 32rpx;">
          <text class="form-label">API 提供商</text>
          <view class="custom-select-container">
            <view class="form-picker {{ showProviderPicker ? 'active' : '' }}" bindtap="onToggleProviderPicker">
              <text>{{ providers[selectedProviderIndex] }}</text>
              <text class="iconfont iconfont-down-line select-arrow {{ showProviderPicker ? 'open' : '' }}"></text>
            </view>
            <view class="custom-select-options {{ showProviderPicker ? 'show' : '' }}">
              <view
                class="custom-select-option {{ selectedProviderIndex === index ? 'selected' : '' }}"
                wx:for="{{ providers }}"
                wx:key="index"
                bindtap="onSelectProvider"
                data-index="{{ index }}"
              >
                <text>{{ item }}</text>
              </view>
            </view>
            <view class="custom-select-backdrop" wx:if="{{ showProviderPicker }}" bindtap="onCloseProviderPicker"></view>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">API Key</text>
          <input
            class="input-field"
            placeholder="请输入 API 密鑰 (API Key)..."
            password="true"
            value="{{ apiKey }}"
            bindinput="onApiKeyInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">API Base URL (端点)</text>
          <input
            class="input-field"
            placeholder="例如: https://api.deepseek.com/v1"
            value="{{ baseUrl }}"
            bindinput="onBaseUrlInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">模型名称 (Model Name)</text>
          <input
            class="input-field"
            placeholder="例如: deepseek-chat / gpt-4o-mini"
            value="{{ modelName }}"
            bindinput="onModelNameInput"
          />
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onSaveConfig"
          disabled="{{ saving }}"
          style="margin-top: 16rpx;"
        >
          {{ saving ? '保存中...' : '保存配置' }}
        </button>
      </view>
    </view>

    <!-- 修改家庭名称 Modal -->
    <view class="modal-mask" wx:if="{{ showRenameFamilyModal }}" bindtap="onCloseRenameFamilyModal">
      <view class="modal-sheet" catchtap="noop" style="padding-bottom: 80rpx;">
        <view class="modal-header">
          <text class="modal-title">修改家庭名称</text>
          <view class="modal-close" bindtap="onCloseRenameFamilyModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">家庭新名称</text>
          <input
            class="input-field"
            placeholder="请输入新的家庭名称"
            value="{{ renameFamilyName }}"
            bindinput="onRenameFamilyNameInput"
          />
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onCommitRenameFamily"
          style="margin-top: 16rpx;"
        >
          确认修改
        </button>
      </view>
    </view>

    <!-- 编辑成员 Modal -->
    <view class="modal-mask" wx:if="{{ showEditMemberModal }}" bindtap="onCloseEditMemberModal">
      <view class="modal-sheet" catchtap="noop" style="padding-bottom: 80rpx;">
        <view class="modal-header">
          <text class="modal-title">修改昵称</text>
          <view class="modal-close" bindtap="onCloseEditMemberModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">成员昵称</text>
          <input
            class="input-field"
            placeholder="请输入成员昵称"
            value="{{ editMemberNickname }}"
            bindinput="onEditMemberNicknameInput"
          />
        </view>

        <view class="form-group" wx:if="{{ editMemberRole !== 'admin' }}">
          <text class="form-label">成员角色</text>
          <view class="custom-select-container open-up">
            <view class="form-picker {{ showEditMemberRolePicker ? 'active' : '' }}" bindtap="onToggleEditMemberRolePicker">
              <text>{{ editMemberRole === 'write' ? '家人 (可读写)' : '阿姨 (只读)' }}</text>
              <text class="iconfont iconfont-down-line select-arrow {{ showEditMemberRolePicker ? 'open' : '' }}"></text>
            </view>
            <view class="custom-select-options {{ showEditMemberRolePicker ? 'show' : '' }}">
              <view
                class="custom-select-option {{ editMemberRole === 'write' ? 'selected' : '' }}"
                bindtap="onSelectEditMemberRole"
                data-role="write"
              >
                <text>家人 (可读写)</text>
              </view>
              <view
                class="custom-select-option {{ editMemberRole === 'read' ? 'selected' : '' }}"
                bindtap="onSelectEditMemberRole"
                data-role="read"
              >
                <text>阿姨 (只读)</text>
              </view>
            </view>
            <view class="custom-select-backdrop" wx:if="{{ showEditMemberRolePicker }}" bindtap="onCloseEditMemberRolePicker"></view>
          </view>
        </view>

        <button
          class="btn-primary"
          hover-class="btn-primary-hover"
          bindtap="onCommitEditMember"
          style="margin-top: 16rpx;"
        >
          确认保存
        </button>
      </view>
    </view>

    <!-- 通用确认 Modal -->
    <view class="modal-mask" wx:if="{{ showConfirmModal }}" bindtap="onCloseConfirmModal">
      <view class="modal-sheet" catchtap="noop" style="padding-bottom: 60rpx; text-align: center;">
        <view class="modal-header" style="border: none; padding-bottom: 0;">
          <view style="flex: 1;"></view>
          <view class="modal-close" bindtap="onCloseConfirmModal">
            <text class="iconfont iconfont-wrong"></text>
          </view>
        </view>
        <view style="margin-bottom: 24rpx; display: inline-block;">
          <text class="iconfont iconfont-info" style="font-size: 80rpx; color: #E53935;"></text>
        </view>
        <view style="font-size: 32rpx; font-weight: 700; color: var(--text-main); margin-bottom: 16rpx;">{{ confirmTitle }}</view>
        <view style="font-size: 26rpx; color: var(--text-muted); line-height: 1.6; padding: 0 32rpx; margin-bottom: 40rpx;">{{ confirmContent }}</view>
        <view style="display: flex; gap: 20rpx; padding: 0 32rpx;">
          <button class="btn-secondary" style="flex: 1; border: 1rpx solid #E0E0E0; background: #FFF; color: #666; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600;" bindtap="onCloseConfirmModal">取消</button>
          <button class="btn-primary" style="flex: 1; background: #E53935; font-size: 28rpx; height: 84rpx; display: flex; align-items: center; justify-content: center; font-weight: 600; box-shadow: none;" bindtap="onCommitConfirm">确认</button>
        </view>
      </view>
    </view>

  </block>

  <!-- 自定义 Toast & Loading -->
  <view class="custom-toast-backdrop" wx:if="{{ toastData.show }}" catchtap="noop" catchtouchmove="noop"></view>
  <view class="custom-toast {{ toastData.show ? 'show' : '' }}">
    <view class="custom-toast-content">
      <view class="custom-toast-loading-spinner" wx:if="{{ toastData.type === 'loading' }}"></view>
      <text class="iconfont iconfont-success custom-toast-icon success" wx:elif="{{ toastData.type === 'success' }}"></text>
      <text class="iconfont iconfont-info custom-toast-icon info" wx:elif="{{ toastData.type === 'info' }}"></text>
      <text class="custom-toast-title" wx:if="{{ toastData.title }}">{{ toastData.title }}</text>
    </view>
  </view>
</view>
